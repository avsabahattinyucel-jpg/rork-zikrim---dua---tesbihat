{
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/cron/khutbah-summary",
      "schedule": "0 4 * * 5"
    }
  ],
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/kvkk",
      "destination": "/kvkk.html"
    },
    {
      "source": "/support",
      "destination": "/support.html"
    }
  ],
  "redirects": [
    {
      "source": "/terms",
      "destination": "https://www.apple.com/legal/internet-services/itunes/dev/stdeula/",
      "permanent": true
    }
  ]
}
