{
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/cron/khutbah-summary",
      "schedule": "0 4 * * 5"
    }
  ],
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/support",
      "destination": "/support.html"
    }
  ]
}
