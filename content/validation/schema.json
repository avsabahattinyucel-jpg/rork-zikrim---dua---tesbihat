{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zikrim.app/schemas/hisnul-muslim-content-system.json",
  "$defs": {
    "supportedLanguage": {
      "enum": ["tr", "ar", "en", "fr", "de", "id", "ms", "fa", "ru", "es", "ur"]
    },
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tr", "ar", "en", "fr", "de", "id", "ms", "fa", "ru", "es", "ur"],
      "properties": {
        "tr": { "type": "string", "minLength": 1 },
        "ar": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 },
        "fr": { "type": "string", "minLength": 1 },
        "de": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "ms": { "type": "string", "minLength": 1 },
        "fa": { "type": "string", "minLength": 1 },
        "ru": { "type": "string", "minLength": 1 },
        "es": { "type": "string", "minLength": 1 },
        "ur": { "type": "string", "minLength": 1 }
      }
    },
    "categoryTitleText": { "$ref": "#/$defs/localizedText" },
    "transliterationText": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tr": { "type": "string", "minLength": 1 },
        "ar": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 },
        "fr": { "type": "string", "minLength": 1 },
        "de": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "ms": { "type": "string", "minLength": 1 },
        "fa": { "type": "string", "minLength": 1 },
        "ru": { "type": "string", "minLength": 1 },
        "es": { "type": "string", "minLength": 1 },
        "ur": { "type": "string", "minLength": 1 }
      }
    },
    "sourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_book", "source_type"],
      "properties": {
        "primary_book": { "type": "string", "minLength": 1 },
        "hadith_reference": { "type": "string", "minLength": 1 },
        "narrator_optional": { "type": "string", "minLength": 1 },
        "source_type": { "enum": ["hadith", "quran", "general_dua"] }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "notes"],
      "properties": {
        "status": { "enum": ["verified", "needs_review", "unknown"] },
        "notes": { "type": "string", "minLength": 1 },
        "last_reviewed_at": { "type": "string", "format": "date-time" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order_index",
        "popularity_weight",
        "is_featured",
        "recommended_for_premium",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "order_index": { "type": "integer", "minimum": 0 },
        "popularity_weight": { "type": "integer", "minimum": 0 },
        "is_featured": { "type": "boolean" },
        "recommended_for_premium": { "type": "boolean" },
        "reflection_available": { "type": "boolean" },
        "audio_available": { "type": "boolean" },
        "ai_reflection_available": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "dua": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "collection",
        "category_id",
        "category_title",
        "title",
        "arabic_text",
        "transliteration",
        "meaning",
        "short_explanation",
        "usage_context",
        "source",
        "verification",
        "metadata"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "collection": { "type": "string", "minLength": 1 },
        "category_id": { "type": "string", "minLength": 1 },
        "category_title": { "$ref": "#/$defs/categoryTitleText" },
        "title": { "$ref": "#/$defs/localizedText" },
        "arabic_text": { "type": "string" },
        "transliteration": { "$ref": "#/$defs/transliterationText" },
        "meaning": { "$ref": "#/$defs/localizedText" },
        "short_explanation": { "$ref": "#/$defs/localizedText" },
        "usage_context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tags"],
          "properties": {
            "tags": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            },
            "derived_tags": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "emotional_states": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "guide_tab_hints": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "source": { "$ref": "#/$defs/sourceReference" },
        "verification": { "$ref": "#/$defs/verification" },
        "metadata": { "$ref": "#/$defs/metadata" },
        "guide": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primary_tab_id": { "type": "string", "minLength": 1 },
            "suggested_tab_ids": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "duaDataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "collection", "generated_at", "duas"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "collection": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "format": "date-time" },
        "duas": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/dua" }
        }
      }
    },
    "duaCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "icon_name", "sort_order", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "$ref": "#/$defs/localizedText" },
        "icon_name": { "type": "string", "minLength": 1 },
        "sort_order": { "type": "integer", "minimum": 0 },
        "description": { "$ref": "#/$defs/localizedText" }
      }
    },
    "duaCategoryDataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "generated_at", "categories"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "generated_at": { "type": "string", "format": "date-time" },
        "categories": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/duaCategory" }
        }
      }
    },
    "guideTab": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "short_description",
        "icon_name",
        "sort_order",
        "related_dua_category_ids"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "$ref": "#/$defs/localizedText" },
        "short_description": { "$ref": "#/$defs/localizedText" },
        "icon_name": { "type": "string", "minLength": 1 },
        "sort_order": { "type": "integer", "minimum": 0 },
        "related_dua_category_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "featured_dua_id": { "type": "string", "minLength": 1 },
        "legacy_guide_tab_id": { "type": "string", "minLength": 1 }
      }
    },
    "guideTabDataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "generated_at", "tabs"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "generated_at": { "type": "string", "format": "date-time" },
        "tabs": {
          "type": "array",
          "items": { "$ref": "#/$defs/guideTab" }
        }
      }
    },
    "guideMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "dua_category_id", "guide_tab_id", "strategy", "reason"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "dua_category_id": { "type": "string", "minLength": 1 },
        "guide_tab_id": { "type": "string", "minLength": 1 },
        "strategy": { "enum": ["merge_existing", "create_new"] },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "guideMappingDataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "generated_at", "mappings"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "generated_at": { "type": "string", "format": "date-time" },
        "mappings": {
          "type": "array",
          "items": { "$ref": "#/$defs/guideMapping" }
        }
      }
    }
  }
}
