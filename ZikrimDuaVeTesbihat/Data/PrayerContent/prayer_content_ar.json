{
  "version": 1,
  "language": "ar",
  "notes": [
    "أُبقيت النصوص قصيرة لتناسب الاستخدام داخل التطبيق.",
    "نصوص الآيات والأحاديث هنا صيغ موجزة للمعنى وليست ترجمات حرفية كاملة.",
    "يُنصح بالتحقق من المصادر ومراجعتها من محرر ديني مؤهل قبل الاستخدام في بيئة الإنتاج."
  ],
  "categories": {
    "sabah": [
      {
        "id": 1,
        "type": "dua",
        "text": "اللهمّ ابدأ يومي بالخير والسعة والمتاع."
      },
      {
        "id": 2,
        "type": "dua",
        "text": "ربي نور قلبي بنورك وزين لساني بذكرك."
      },
      {
        "id": 3,
        "type": "dua",
        "text": "اللهم اهدني اليوم للصواب واصرف عني الباطل."
      },
      {
        "id": 4,
        "type": "dua",
        "text": "يا رب سهل عملي وأعطي الطمأنينة لقلبي."
      },
      {
        "id": 5,
        "type": "dua",
        "text": "اللهم ارزقني الرزق الحلال والنية الطيبة."
      },
      {
        "id": 6,
        "type": "dua",
        "text": "يا رب اجعل هذا اليوم سببا للسلام لي ولأحبتي."
      },
      {
        "id": 7,
        "type": "dua",
        "text": "اللهم افتح صباحي بالإيمان والثقة والسلام."
      },
      {
        "id": 8,
        "type": "dua",
        "text": "ربي أيقظني من الشكر لا من الغفلة."
      },
      {
        "id": 9,
        "type": "dua",
        "text": "اللهمّ لا تفصل لساني اليوم عن الكلام الطيب."
      },
      {
        "id": 10,
        "type": "dua",
        "text": "يا رب طهر قلبي من الأفكار السيئة."
      },
      {
        "id": 11,
        "type": "ayet",
        "text": "«وقرآن الصباح يشهد.»"
      },
      {
        "id": 12,
        "type": "ayet",
        "text": "«سبح بحمد ربك قبل طلوع الشمس»"
      },
      {
        "id": 13,
        "type": "ayet",
        "text": "«واذكر اسم ربك صباحاً ومساءً»"
      },
      {
        "id": 14,
        "type": "ayet",
        "text": "«لا تطمئن القلوب إلا بذكر الله»."
      },
      {
        "id": 15,
        "type": "ayet",
        "text": "«إن مع العسر يسرا»."
      },
      {
        "id": 16,
        "type": "ayet",
        "text": "«من يتوكل على الله فهو حسبه»."
      },
      {
        "id": 17,
        "type": "ayet",
        "text": "«لئن شكرتم لأزيدنكم»."
      },
      {
        "id": 18,
        "type": "ayet",
        "text": "«إن الله مع الصابرين»."
      },
      {
        "id": 19,
        "type": "ayet",
        "text": "«رب زدني علما»."
      },
      {
        "id": 20,
        "type": "ayet",
        "text": "«يريد الله بكم اليسر، ولا يريد بكم العسر»."
      },
      {
        "id": 21,
        "type": "hadis",
        "text": "«اللهم اجعل عمل أمتي في الصبح مثمراً»"
      },
      {
        "id": 22,
        "type": "hadis",
        "text": "«من صلى الصبح فهو في ذمة الله»."
      },
      {
        "id": 23,
        "type": "hadis",
        "text": "«من صلى البردتين دخل الجنة»."
      },
      {
        "id": 24,
        "type": "hadis",
        "text": "«أحب الأعمال إلى الله أدومها وإن قل»."
      },
      {
        "id": 25,
        "type": "hadis",
        "text": "«الصلاة جوهر العبادة.»"
      },
      {
        "id": 26,
        "type": "hadis",
        "text": "«النظافة نصف الإيمان»."
      },
      {
        "id": 27,
        "type": "hadis",
        "text": "«اجعل الأمر سهلاً، ولا تجعله صعباً.»"
      },
      {
        "id": 28,
        "type": "hadis",
        "text": "«من لا يرحم لا يُرحم.»"
      },
      {
        "id": 29,
        "type": "hadis",
        "text": "«عجباً لعمل المؤمن، وكل حاله خير له»."
      },
      {
        "id": 30,
        "type": "hadis",
        "text": "«من عمل خيرا فله أجره أيضا»."
      },
      {
        "id": 31,
        "type": "dua",
        "text": "اللهم اجعل اليوم بداية مثمرة."
      },
      {
        "id": 32,
        "type": "dua",
        "text": "يا رب، أعط السلام لقلبي والقوة لجسدي."
      },
      {
        "id": 33,
        "type": "dua",
        "text": "اللهمّ اهدني اليوم إلى أبواب الخير."
      },
      {
        "id": 34,
        "type": "dua",
        "text": "رب اجعل رزقي حلالاً، وقلباً نقياً."
      },
      {
        "id": 35,
        "type": "dua",
        "text": "اللهم إني أعوذ بك من شر نفسي."
      },
      {
        "id": 36,
        "type": "dua",
        "text": "ربي قارني اليوم مع الناس الطيبين."
      },
      {
        "id": 37,
        "type": "dua",
        "text": "اللهمّ أوزعني أن أشكر النعم التي عليّ."
      },
      {
        "id": 38,
        "type": "dua",
        "text": "ربي أحاط صباحي برحمتك."
      },
      {
        "id": 39,
        "type": "dua",
        "text": "اللهم احفظني من الأشياء التي تحرجني."
      },
      {
        "id": 40,
        "type": "dua",
        "text": "يا رب، ساعدني على اتخاذ قرارات حكيمة اليوم."
      },
      {
        "id": 41,
        "type": "ayet",
        "text": "«إنه يخلق الصباح.»"
      },
      {
        "id": 42,
        "type": "ayet",
        "text": "\"والله على كل شيء وكيل\"."
      },
      {
        "id": 43,
        "type": "ayet",
        "text": "«قل رب أدخلني بالحق وأخرجني بالحق»."
      },
      {
        "id": 44,
        "type": "ayet",
        "text": "«إن الله يحب المحسنين»."
      },
      {
        "id": 45,
        "type": "ayet",
        "text": "«رب اجعلني من المصلين»."
      },
      {
        "id": 46,
        "type": "ayet",
        "text": "«وما أرسلناك إلا رحمة للعالمين»."
      },
      {
        "id": 47,
        "type": "ayet",
        "text": "«إن نصر الله قريب»."
      },
      {
        "id": 48,
        "type": "ayet",
        "text": "«قال ربكم ادعوني أستجب لكم»"
      },
      {
        "id": 49,
        "type": "ayet",
        "text": "«إن الله يأمر بالعدل والإحسان»."
      },
      {
        "id": 50,
        "type": "ayet",
        "text": "«إنما يجزي الإنسان ما عمل»."
      }
    ],
    "ogle": [
      {
        "id": 1,
        "type": "dua",
        "text": "اللهمّ جدّد قلبي في منتصف النهار وأصلح نيتي."
      },
      {
        "id": 2,
        "type": "dua",
        "text": "يا رب اجعل هذا الوقت زمن سلام وطمأنينة."
      },
      {
        "id": 3,
        "type": "dua",
        "text": "يا إلهي أزل همي وأعطني الثقة."
      },
      {
        "id": 4,
        "type": "dua",
        "text": "ربي اجعلني من عبادك الصالحين الصالحين."
      },
      {
        "id": 5,
        "type": "dua",
        "text": "اللهم حول جهدي اليوم إلى خير."
      },
      {
        "id": 6,
        "type": "dua",
        "text": "ربي وسع في رزقي وحكمة في كلامي."
      },
      {
        "id": 7,
        "type": "dua",
        "text": "اللهمّ أرزقني العيش دون أن يكسر قلبي أو يكسره."
      },
      {
        "id": 8,
        "type": "dua",
        "text": "يا رب أعطني اللطف بدلاً من الغضب."
      },
      {
        "id": 9,
        "type": "dua",
        "text": "اللهم آمنني عن حقوق الناس."
      },
      {
        "id": 10,
        "type": "dua",
        "text": "يا رب امنحني بركة الصلوات المقبولة في هذا الوقت."
      },
      {
        "id": 11,
        "type": "ayet",
        "text": "«أقيموا الصلاة وآتوا الزكاة»."
      },
      {
        "id": 12,
        "type": "ayet",
        "text": "«فاذكروني أذكركم»"
      },
      {
        "id": 13,
        "type": "ayet",
        "text": "«إن الصلاة تنهى عن الفحشاء والمنكر»."
      },
      {
        "id": 14,
        "type": "ayet",
        "text": "«تعاونوا على البر والتقوى»."
      },
      {
        "id": 15,
        "type": "ayet",
        "text": "«إن الله يحب المقسطين»."
      },
      {
        "id": 16,
        "type": "ayet",
        "text": "«إن ربكم ذو رحمة عظيمة»."
      },
      {
        "id": 17,
        "type": "ayet",
        "text": "«اصبر فإن الله لا يضيع أجر المحسنين»."
      },
      {
        "id": 18,
        "type": "ayet",
        "text": "«كل نعمة من الله»."
      },
      {
        "id": 19,
        "type": "ayet",
        "text": "«إن الله خبير بأعمالكم»."
      },
      {
        "id": 20,
        "type": "ayet",
        "text": "«إن الله لا يحب المسرفين»."
      },
      {
        "id": 21,
        "type": "hadis",
        "text": "«أحب الأعمال إلى الله الصلاة لوقتها»."
      },
      {
        "id": 22,
        "type": "hadis",
        "text": "«يسر الأمر، ولا تجعله صعبًا، وبشر بالخير، ولا تجعل الناس يكرهون.»"
      },
      {
        "id": 23,
        "type": "hadis",
        "text": "«القوي من يملك غضبه»."
      },
      {
        "id": 24,
        "type": "hadis",
        "text": "«المسلم من وثق الناس بيده ولسانه»."
      },
      {
        "id": 25,
        "type": "hadis",
        "text": "«ما دام الله في عون العبد كان العبد في عون أخيه»."
      },
      {
        "id": 26,
        "type": "hadis",
        "text": "«ابتسامتك صدقة»"
      },
      {
        "id": 27,
        "type": "hadis",
        "text": "«خير الناس من هو نافع للناس»."
      },
      {
        "id": 28,
        "type": "hadis",
        "text": "«خير الأمور أوسطها»."
      },
      {
        "id": 29,
        "type": "hadis",
        "text": "«إن الله رفيق يحب الرفق»."
      },
      {
        "id": 30,
        "type": "hadis",
        "text": "«ما أكل أحد لقمة قط خيرًا من كسبه»."
      },
      {
        "id": 31,
        "type": "dua",
        "text": "اللهم احفظ قلبي من الغفلة في منتصف النهار."
      },
      {
        "id": 32,
        "type": "dua",
        "text": "ربي ارزقني دخلاً حلالاً وضميراً طاهراً."
      },
      {
        "id": 33,
        "type": "dua",
        "text": "اللهمّ حوّل تعبي اليوم إلى حسنات."
      },
      {
        "id": 34,
        "type": "dua",
        "text": "ربي علمني أن أكبح جشع نفسي."
      },
      {
        "id": 35,
        "type": "dua",
        "text": "اللهم اكفني من تسرع الأحكام."
      },
      {
        "id": 36,
        "type": "dua",
        "text": "ربي ثبت لساني على الحق."
      },
      {
        "id": 37,
        "type": "dua",
        "text": "اللهم املأ وقتي بما هو نافع."
      },
      {
        "id": 38,
        "type": "dua",
        "text": "يا رب أعطني السلام في هذا الوقت من اليوم."
      },
      {
        "id": 39,
        "type": "dua",
        "text": "اللهم ارزقني كرامة أن أكون عبدا."
      },
      {
        "id": 40,
        "type": "dua",
        "text": "ربي ارزق قلبي الطمأنينة."
      },
      {
        "id": 41,
        "type": "ayet",
        "text": "«يريد الله لكم اليسر لا العسر»"
      },
      {
        "id": 42,
        "type": "ayet",
        "text": "«إن الله غفور رحيم»."
      },
      {
        "id": 43,
        "type": "ayet",
        "text": "«أخبرني عن نعمة ربك»."
      },
      {
        "id": 44,
        "type": "ayet",
        "text": "«لا تستوي الحسنة والسيئة، ادفعوا بالتي هي أحسن»."
      },
      {
        "id": 45,
        "type": "ayet",
        "text": "«إن الله مع الصالحين»."
      },
      {
        "id": 46,
        "type": "ayet",
        "text": "«قل هل يستوي الذين يعلمون والذين لا يعلمون؟»"
      },
      {
        "id": 47,
        "type": "ayet",
        "text": "«رب اشرح صدري»"
      },
      {
        "id": 48,
        "type": "ayet",
        "text": "«إنما يستحق المرء ما يعمل من أجله»."
      },
      {
        "id": 49,
        "type": "ayet",
        "text": "«إن الله يحب الصابرين»."
      },
      {
        "id": 50,
        "type": "ayet",
        "text": "«عباد الرحمن يمشون على الأرض هوناً»."
      }
    ],
    "ikindi": [
      {
        "id": 1,
        "type": "dua",
        "text": "ربنا يقدرنا على إكمال بقية يومنا على الخير."
      },
      {
        "id": 2,
        "type": "dua",
        "text": "ربي جميل تعبي بالصبر."
      },
      {
        "id": 3,
        "type": "dua",
        "text": "اللهم احفظ قلبي من كل ما يشتت انتباهي في هذا الوقت."
      },
      {
        "id": 4,
        "type": "dua",
        "text": "ربي اجعل نهايتي خير من بدايتي."
      },
      {
        "id": 5,
        "type": "dua",
        "text": "اللهم جنبني التسرع والغضب وكلام الجار."
      },
      {
        "id": 6,
        "type": "dua",
        "text": "يا رب امنحني القدرة على إنهاء عملي بدقة."
      },
      {
        "id": 7,
        "type": "dua",
        "text": "اللهم اغفر لي الأخطاء التي ارتكبتها طوال اليوم."
      },
      {
        "id": 8,
        "type": "dua",
        "text": "ربي أدخل السكينة على قلبي مع اقتراب المساء."
      },
      {
        "id": 9,
        "type": "dua",
        "text": "اللهم احفظني من الإسراف والتبذير."
      },
      {
        "id": 10,
        "type": "dua",
        "text": "ربي أعطني صفاء الذهن وصفاء القلب."
      },
      {
        "id": 11,
        "type": "ayet",
        "text": "«أستمر في الصلاة الوسطى»."
      },
      {
        "id": 12,
        "type": "ayet",
        "text": "«إن للذين أحسنوا خيرا و أكثر»."
      },
      {
        "id": 13,
        "type": "ayet",
        "text": "«إن الله مع المحسنين»."
      },
      {
        "id": 14,
        "type": "ayet",
        "text": "«لا يكلف الله أحداً إلا وسعه»."
      },
      {
        "id": 15,
        "type": "ayet",
        "text": "\"وإن ربك غفور رحيم\"."
      },
      {
        "id": 16,
        "type": "ayet",
        "text": "«إن الله يكفي المتوكلين»."
      },
      {
        "id": 17,
        "type": "ayet",
        "text": "«فاعبدني وحدي»."
      },
      {
        "id": 18,
        "type": "ayet",
        "text": "«إن ربك وسع كل شيء»."
      },
      {
        "id": 19,
        "type": "ayet",
        "text": "«إن الله معكم لا يحبط أعمالكم»."
      },
      {
        "id": 20,
        "type": "ayet",
        "text": "«لا تهن ولا تحزن إن آمنت فأنت الأعلى»."
      },
      {
        "id": 21,
        "type": "hadis",
        "text": "«من ترك صلاة العصر حبط عمله»."
      },
      {
        "id": 22,
        "type": "hadis",
        "text": "«من صلى البردتين دخل الجنة»."
      },
      {
        "id": 23,
        "type": "hadis",
        "text": "«عمل المؤمن حسن، إذا فرح شكر، وإذا حزن صبر»."
      },
      {
        "id": 24,
        "type": "hadis",
        "text": "«إن الله جميل يحب الجمال»."
      },
      {
        "id": 25,
        "type": "hadis",
        "text": "\"لا تحقدوا على بعضكم بعضاً، وكونوا إخوة\"."
      },
      {
        "id": 26,
        "type": "hadis",
        "text": "«ما نقصت صدقة من مال»."
      },
      {
        "id": 27,
        "type": "hadis",
        "text": "«سيلا رحيم تجعل الحياة مثمرة.»"
      },
      {
        "id": 28,
        "type": "hadis",
        "text": "«حتى لو جاءت نهاية العالم، إذا كان لديك شتلة، فازرعها.»"
      },
      {
        "id": 29,
        "type": "hadis",
        "text": "«إن خير الناس أحسنهم أخلاقًا»."
      },
      {
        "id": 30,
        "type": "hadis",
        "text": "«إن الله يعطي العبد الخير إذا رفق»."
      },
      {
        "id": 31,
        "type": "dua",
        "text": "يا الله، أعطني القوة لتدعمني حتى نهاية اليوم."
      },
      {
        "id": 32,
        "type": "dua",
        "text": "ربي امنح قلبي الصبر والكرامة."
      },
      {
        "id": 33,
        "type": "dua",
        "text": "اللهم تقبل مني صالح الأعمال التي قمت بها اليوم."
      },
      {
        "id": 34,
        "type": "dua",
        "text": "ربي أكمل عيوبي برحمتك."
      },
      {
        "id": 35,
        "type": "dua",
        "text": "اللهم احفظني من زلة اللسان وحسرة القلب."
      },
      {
        "id": 36,
        "type": "dua",
        "text": "يا رب، أعط حكمة لعقلي ورحمة لقلبي."
      },
      {
        "id": 37,
        "type": "dua",
        "text": "اللهمّ اغفر لمن أخطأت في حقه اليوم."
      },
      {
        "id": 38,
        "type": "dua",
        "text": "ربي اجعل ما بقي من وقتي نافعا."
      },
      {
        "id": 39,
        "type": "dua",
        "text": "اللهم حذرني حيث تخدعني نفسي."
      },
      {
        "id": 40,
        "type": "dua",
        "text": "ربي اجعلني من الصابرين."
      },
      {
        "id": 41,
        "type": "ayet",
        "text": "«تنافسوا في الخير.»"
      },
      {
        "id": 42,
        "type": "ayet",
        "text": "«إن الله يجزي الصابرين بغير حساب»."
      },
      {
        "id": 43,
        "type": "ayet",
        "text": "«من يعمل مثقال ذرة من الخير يره»."
      },
      {
        "id": 44,
        "type": "ayet",
        "text": "«وسيجزي الله الشاكرين»."
      },
      {
        "id": 45,
        "type": "ayet",
        "text": "«خلق لكم السمع والأبصار والأفئدة»."
      },
      {
        "id": 46,
        "type": "ayet",
        "text": "\"إن الله يحب التوابين\"."
      },
      {
        "id": 47,
        "type": "ayet",
        "text": "«إن الله مع المتقين»."
      },
      {
        "id": 48,
        "type": "ayet",
        "text": "«رب اغفر لي ولوالدي»"
      },
      {
        "id": 49,
        "type": "ayet",
        "text": "«إن الله خير حافظا»."
      },
      {
        "id": 50,
        "type": "ayet",
        "text": "«واصبر لحكم ربك»."
      }
    ],
    "aksam": [
      {
        "id": 1,
        "type": "dua",
        "text": "اللهمّ اقض هذا المساء بالأمن والسلام والمرح."
      },
      {
        "id": 2,
        "type": "dua",
        "text": "يا رب ارزقنا أن نحاسب يومنا بالخير."
      },
      {
        "id": 3,
        "type": "dua",
        "text": "إلهي أمحو التعب في قلبي برحمتك."
      },
      {
        "id": 4,
        "type": "dua",
        "text": "ربي اجعل أمسي جميلاً بذكرك."
      },
      {
        "id": 5,
        "type": "dua",
        "text": "اللهمّ أعطِ السلامًا لأهلي، والسعة في بيتي."
      },
      {
        "id": 6,
        "type": "dua",
        "text": "يا رب اغفر لي الأخطاء التي ارتكبتها خلال النهار."
      },
      {
        "id": 7,
        "type": "dua",
        "text": "اللهم اجعل ليلتي سلاماً لا خوفاً."
      },
      {
        "id": 8,
        "type": "dua",
        "text": "يا رب احفظنا بنورك حتى في الظلام."
      },
      {
        "id": 9,
        "type": "dua",
        "text": "اللهمّ اجعل هذا المساء باباً من أبواب الخير."
      },
      {
        "id": 10,
        "type": "dua",
        "text": "يا رب احفظ أحبائي من الشر المرئي وغير المرئي."
      },
      {
        "id": 11,
        "type": "ayet",
        "text": "«فسبحوا الله حين تصبحون»"
      },
      {
        "id": 12,
        "type": "ayet",
        "text": "«و جعل لكم الليل لباسا»."
      },
      {
        "id": 13,
        "type": "ayet",
        "text": "«صلوا طرفي النهار و زلفاً من الليل»."
      },
      {
        "id": 14,
        "type": "ayet",
        "text": "\"إن ملاحقة ربك عسير\"."
      },
      {
        "id": 15,
        "type": "ayet",
        "text": "«الله نور السماوات والأرض»."
      },
      {
        "id": 16,
        "type": "ayet",
        "text": "«هو الذي خلق الليل لتسكنوا»"
      },
      {
        "id": 17,
        "type": "ayet",
        "text": "«قل: رب أعوذ بك من همزات الشياطين»."
      },
      {
        "id": 18,
        "type": "ayet",
        "text": "«رب أنزلني مكاناً مباركاً»"
      },
      {
        "id": 19,
        "type": "ayet",
        "text": "«\"كفى بالله وكيلا\"»"
      },
      {
        "id": 20,
        "type": "ayet",
        "text": "«إنه شديد الرأفة والرحمة بعباده»."
      },
      {
        "id": 21,
        "type": "hadis",
        "text": "«إذا أمسيت فخذ أولادك معك فإن ذلك حين تنتشر الشياطين»"
      },
      {
        "id": 22,
        "type": "hadis",
        "text": "«من أصبح يذكر المساء فهو محفوظ»."
      },
      {
        "id": 23,
        "type": "hadis",
        "text": "«اللهم أصبحنا باسمك أصبحنا.»"
      },
      {
        "id": 24,
        "type": "hadis",
        "text": "«إذا بات العبد على وضوء صلّى عليه الملك»."
      },
      {
        "id": 25,
        "type": "hadis",
        "text": "«إن الرحمن يرحم من يرحم»."
      },
      {
        "id": 26,
        "type": "hadis",
        "text": "«إذا دعا المؤمن لأخيه بغيبة قال الملك: آمين»."
      },
      {
        "id": 27,
        "type": "hadis",
        "text": "«من فرج عن مسلم كربة فرج الله عنه كربة»."
      },
      {
        "id": 28,
        "type": "hadis",
        "text": "«إن التوبة لمن تاب قبل الليل تقبل التوبة»."
      },
      {
        "id": 29,
        "type": "hadis",
        "text": "«أنشروا التحيات.»"
      },
      {
        "id": 30,
        "type": "ayet",
        "text": "«يثبت الله الذين آمنوا بالقول الثابت»."
      },
      {
        "id": 31,
        "type": "dua",
        "text": "اللهم تقبل مني صالح الأعمال التي قمت بها اليوم."
      },
      {
        "id": 32,
        "type": "dua",
        "text": "يا رب املأ أمسي بالسلام وليس بالندم."
      },
      {
        "id": 33,
        "type": "dua",
        "text": "إلهي أعط قلبي السكينة التي تليق بالليل."
      },
      {
        "id": 34,
        "type": "dua",
        "text": "ربي احفظني من كل سوء في السر والعلن."
      },
      {
        "id": 35,
        "type": "dua",
        "text": "اللهم اجعل بيتي دار رحمة ومحبة وأمان."
      },
      {
        "id": 36,
        "type": "dua",
        "text": "يا رب، قرّب قلبي إليك في هذا المساء."
      },
      {
        "id": 37,
        "type": "dua",
        "text": "اللهم أصلح لي دنياي وآخرتي."
      },
      {
        "id": 38,
        "type": "dua",
        "text": "يا رب، زِد وعيي بالبركات الممنوحة لي اليوم."
      },
      {
        "id": 39,
        "type": "dua",
        "text": "اللهم حبب إلي العفو والرفق."
      },
      {
        "id": 40,
        "type": "dua",
        "text": "ربي أنزل السكينة علي في المساء."
      },
      {
        "id": 41,
        "type": "ayet",
        "text": "«سبح اسم ربك مساءا وصباحا»"
      },
      {
        "id": 42,
        "type": "ayet",
        "text": "\"اسجد بالليل وسبحه طولا\"."
      },
      {
        "id": 43,
        "type": "ayet",
        "text": "«إن قيام الليل أبلغ وأوثق من حيث التلاوة»."
      },
      {
        "id": 44,
        "type": "ayet",
        "text": "«قد جعل الله لكل شيء قدرا»."
      },
      {
        "id": 45,
        "type": "ayet",
        "text": "«ولا تقنط من رحمة ربك»"
      },
      {
        "id": 46,
        "type": "ayet",
        "text": "«والله خير حافظاً»."
      },
      {
        "id": 47,
        "type": "ayet",
        "text": "«إنه ينامك بالليل كأنه يقتلك.»"
      },
      {
        "id": 48,
        "type": "ayet",
        "text": "\"لا تدركه العيون، وهو يدرك العيون\"."
      },
      {
        "id": 49,
        "type": "ayet",
        "text": "«حسبك الله فنعم الوكيل»."
      },
      {
        "id": 50,
        "type": "ayet",
        "text": "«ومن يتكل علي فلا يضيع.»"
      }
    ],
    "yatsi": [
      {
        "id": 1,
        "type": "dua",
        "text": "اللهم اجعل ليلتي سكينة ونومي راحة."
      },
      {
        "id": 2,
        "type": "dua",
        "text": "يا رب احفظ قلبي بنورك حتى في ظلام الليل."
      },
      {
        "id": 3,
        "type": "dua",
        "text": "إلهي أمنني من المخاوف واجبر قلبي."
      },
      {
        "id": 4,
        "type": "dua",
        "text": "يا رب اغفر لي عيوبي اليوم وأيقظني غدًا أفضل."
      },
      {
        "id": 5,
        "type": "dua",
        "text": "اللهم اجعل فراشي راحة وشفاء."
      },
      {
        "id": 6,
        "type": "dua",
        "text": "يا رب اجعل الليل وقت تأمل وسلام لي."
      },
      {
        "id": 7,
        "type": "dua",
        "text": "اللهم طهر قلبي من الحقد والضغينة."
      },
      {
        "id": 8,
        "type": "dua",
        "text": "ربي اجعلني من عبادك المغفور لهم."
      },
      {
        "id": 9,
        "type": "dua",
        "text": "اللهمّ أعط سلاماً لروحي وراحة لجسدي."
      },
      {
        "id": 10,
        "type": "dua",
        "text": "رب احفظ ليلتي من وساوس الشيطان."
      },
      {
        "id": 11,
        "type": "ayet",
        "text": "«اسجد له في الليل وسبحه طوال الليل الطويل»."
      },
      {
        "id": 12,
        "type": "ayet",
        "text": "«اسجد له في جزء من الليل»."
      },
      {
        "id": 13,
        "type": "ayet",
        "text": "\"إنهم يقضون الليل سجدا وقياما لربهم\"."
      },
      {
        "id": 14,
        "type": "ayet",
        "text": "«لا شك أن الإقلاع ليلاً أكثر فعالية.»"
      },
      {
        "id": 15,
        "type": "ayet",
        "text": "«ولا تقنط من رحمة ربك»"
      },
      {
        "id": 16,
        "type": "ayet",
        "text": "«الله أقرب إليك من حبل الوريد»."
      },
      {
        "id": 17,
        "type": "ayet",
        "text": "«إنه يقتل الأرواح أثناء النوم.»"
      },
      {
        "id": 18,
        "type": "ayet",
        "text": "«رب اغفر لي واغفر لوالدي وللمؤمنين»."
      },
      {
        "id": 19,
        "type": "ayet",
        "text": "«إن الله رؤوف بعباده»."
      },
      {
        "id": 20,
        "type": "ayet",
        "text": "«إن الله على كل شيء قدير»."
      },
      {
        "id": 21,
        "type": "hadis",
        "text": "«من صلى العشاء والفجر في جماعة كان كمن قام الليل»."
      },
      {
        "id": 22,
        "type": "hadis",
        "text": "«إذا قرأت آية الكرسي عند النوم جعل الله حافظا»."
      },
      {
        "id": 23,
        "type": "hadis",
        "text": "«كان رسول الله صلى الله عليه وسلم إذا أوى إلى فراشه قرأ سورة الإخلاص والفلق والناس»."
      },
      {
        "id": 24,
        "type": "hadis",
        "text": "«إذا أويت إلى فراشك فاستلق على شقك الأيمن وصلي»."
      },
      {
        "id": 25,
        "type": "hadis",
        "text": "«اللهم إني أموت وأحيا باسمك.»"
      },
      {
        "id": 26,
        "type": "hadis",
        "text": "«من نام على وضوء بات معه الملك بالليل»."
      },
      {
        "id": 27,
        "type": "hadis",
        "text": "«خير الناس من تعلم القرآن وعلمه»."
      },
      {
        "id": 28,
        "type": "hadis",
        "text": "«إن في الليل ساعة لا ترد فيها الصلاة»."
      },
      {
        "id": 29,
        "type": "hadis",
        "text": "\"يا أيها الناس صلوا بالليل والناس نيام تدخلون الجنة بسلام\"."
      },
      {
        "id": 30,
        "type": "hadis",
        "text": "«أقرب ما يكون العبد من ربه حال السجود»."
      },
      {
        "id": 31,
        "type": "dua",
        "text": "اللهمّ أقمني الليلة مغفوراً له."
      },
      {
        "id": 32,
        "type": "dua",
        "text": "ربي أصلح ما في قلبي من فوضى"
      },
      {
        "id": 33,
        "type": "dua",
        "text": "اللهم اجعل ليلتي مبنية على الثقة لا على الخوف."
      },
      {
        "id": 34,
        "type": "dua",
        "text": "ربي اغفر لي ولمن ظلمني اليوم."
      },
      {
        "id": 35,
        "type": "dua",
        "text": "اللهمّ اجعل الليل شفاءً لروحي."
      },
      {
        "id": 36,
        "type": "dua",
        "text": "ربي اجعلني أنام بنية صافية وقلبًا خفيفًا."
      },
      {
        "id": 37,
        "type": "dua",
        "text": "اللهم إني أعوذ بك من الرؤيا السيئة."
      },
      {
        "id": 38,
        "type": "dua",
        "text": "ربي أجعل نومي هادئاً بعد العبادة."
      },
      {
        "id": 39,
        "type": "dua",
        "text": "يا إلهي ارفعني بالأمل في الغد."
      },
      {
        "id": 40,
        "type": "dua",
        "text": "يا رب اجعل ليلتي مثمرة وصباحي مشرقا."
      },
      {
        "id": 41,
        "type": "ayet",
        "text": "«خلق الليل لتسكنوا»"
      },
      {
        "id": 42,
        "type": "ayet",
        "text": "«إن ربك الذي يعلم تغير الليل والنهار»."
      },
      {
        "id": 43,
        "type": "ayet",
        "text": "«إن الله يحب التوابين»."
      },
      {
        "id": 44,
        "type": "ayet",
        "text": "«إن ربك ذو المغفرة»"
      },
      {
        "id": 45,
        "type": "ayet",
        "text": "«إنه يجيب دعوة المصلي»."
      },
      {
        "id": 46,
        "type": "ayet",
        "text": "\"ومن يتوجه إلى الله فقد يهدى إلى سواء السبيل\"."
      },
      {
        "id": 47,
        "type": "ayet",
        "text": "«إن رحمة الله قريبة من الطيبين»."
      },
      {
        "id": 48,
        "type": "ayet",
        "text": "«إن هناك آيات في الليل والنهار لأولي الألباب»"
      },
      {
        "id": 49,
        "type": "ayet",
        "text": "«إن ربي قريب مني يسمع الدعاء»."
      },
      {
        "id": 50,
        "type": "ayet",
        "text": "«ألقيت عليهم كلمة السلام كلمة من رب رحمن»."
      }
    ]
  }
}
