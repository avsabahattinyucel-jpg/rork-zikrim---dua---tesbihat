        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kredensial Anda tidak dapat diverifikasi. Silakan coba lagi."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kelayakan anda tidak dapat disahkan. Sila cuba lagi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не удалось проверить ваши учетные данные. Попробуйте ещё раз."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kimlik bilgilerin doğrulanamadı. Lütfen tekrar dene."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آپ کی اسناد کی تصدیق نہیں ہو سکی۔ براہ کرم دوبارہ کوشش کریں۔"
          }
        }
      }
    },
    "reauthentication_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لأمانك، يرجى إعادة التحقق قبل حذف هذا الحساب."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zu deiner Sicherheit authentifiziere dich bitte erneut, bevor du dieses Konto löschst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For your security, please reauthenticate before deleting this account."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por tu seguridad, vuelve a autenticarte antes de eliminar esta cuenta."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "برای امنیت شما، لطفاً پیش از حذف این حساب دوباره احراز هویت کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour votre sécurité, veuillez vous réauthentifier avant de supprimer ce compte."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Demi keamanan Anda, silakan autentikasi ulang sebelum menghapus akun ini."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Demi keselamatan anda, sila sahkan semula sebelum memadam akaun ini."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В целях безопасности повторно подтвердите личность перед удалением этого аккаунта."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Güvenliğin için, bu hesabı silmeden önce lütfen yeniden doğrulama yap."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آپ کی حفاظت کے لیے، اس اکاؤنٹ کو حذف کرنے سے پہلے براہ کرم دوبارہ تصدیق کریں۔"
          }
        }
      }
    },
