    "icloud_hesabiniza_giris_yapmaniz_gerekiyor_ayarlar_apple_kimliginiz_icloud_bolumunden_giris_yapin" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحتاج إلى تسجيل الدخول إلى حساب iCloud. اذهب إلى الإعدادات > Apple ID > iCloud."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie müssen sich bei Ihrem iCloud-Konto anmelden. Gehen Sie zu Einstellungen > Ihre Apple-ID > iCloud."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You need to sign in to your iCloud account. Go to Settings > Your Apple ID > iCloud."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Debes iniciar sesión en tu cuenta de iCloud. Ve a Ajustes > Tu Apple ID > iCloud."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لازم است به حساب iCloud خود وارد شوید. به Settings > Apple ID > iCloud بروید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous devez vous connecter à votre compte iCloud. Allez dans Réglages > Votre identifiant Apple > iCloud."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anda harus masuk ke akun iCloud. Buka Pengaturan > Apple ID Anda > iCloud."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anda perlu log masuk ke akaun iCloud. Pergi ke Tetapan > Apple ID anda > iCloud."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Необходимо войти в аккаунт iCloud. Откройте Настройки > Apple ID > iCloud."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud hesabınıza giriş yapmanız gerekiyor. Ayarlar > Apple Kimliğiniz > iCloud bölümünden giriş yapın."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آپ کو iCloud اکاؤنٹ میں سائن اِن کرنا ہوگا۔ Settings > Apple ID > iCloud میں جائیں۔"
          }
