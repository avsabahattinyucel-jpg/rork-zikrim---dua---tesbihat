          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puedes gestionar o cancelar tu suscripción en la configuración de tu cuenta de App Store después de la compra."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "پس از خرید، می‌توانید اشتراک خود را از تنظیمات حساب App Store مدیریت یا لغو کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Après l’achat, vous pouvez gérer ou annuler votre abonnement dans les réglages de votre compte App Store."
