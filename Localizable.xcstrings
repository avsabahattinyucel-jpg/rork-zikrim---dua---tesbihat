        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خرید کی تصدیق پر ادائیگی آپ کے Apple اکاؤنٹ سے وصول کی جاتی ہے۔"
          }
        }
      }
    },
    "paywall_compliance_disclosure_renewal" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم تجديد الاشتراك تلقائيًا ما لم يتم إلغاؤه قبل 24 ساعة على الأقل من نهاية الفترة الحالية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Abo verlängert sich automatisch, sofern es nicht mindestens 24 Stunden vor Ende des aktuellen Zeitraums gekündigt wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Subscription automatically renews unless canceled at least 24 hours before the end of the current period."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La suscripción se renueva automáticamente a menos que se cancele al menos 24 horas antes del final del período actual."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اشتراک به‌صورت خودکار تمدید می‌شود مگر اینکه حداقل ۲۴ ساعت پیش از پایان دوره فعلی لغو شود."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’abonnement se renouvelle automatiquement sauf annulation au moins 24 heures avant la fin de la période en cours."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Langganan akan diperpanjang otomatis kecuali dibatalkan setidaknya 24 jam sebelum periode berjalan berakhir."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Langganan akan diperbaharui secara automatik melainkan dibatalkan sekurang-kurangnya 24 jam sebelum tempoh semasa berakhir."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подписка продлевается автоматически, если её не отменить как минимум за 24 часа до окончания текущего периода."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abonelik, mevcut dönemin bitiminden en az 24 saat önce iptal edilmezse otomatik olarak yenilenir."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سبسکرپشن خودکار طور پر تجدید ہو جاتی ہے جب تک موجودہ مدت ختم ہونے سے کم از کم 24 گھنٹے پہلے اسے منسوخ نہ کیا جائے۔"
          }
        }
      }
    },
    "paywall_compliance_disclosure_renewal_charge" : {
      "extractionState" : "manual",
