    "guide_search_helper_text" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اكتب حالتك باختصار وسنعرض لك أدعية وأذكار مناسبة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beschreibe kurz deine Situation, dann zeigen wir passende Dua- und Dhikr-Empfehlungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Briefly describe your situation and we’ll show suitable dua and dhikr suggestions."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Describe brevemente tu situación y te mostraremos sugerencias adecuadas de dua y dhikr."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شرایط خود را کوتاه بنویسید تا دعا و ذکرهای مناسب به شما نشان داده شود."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Décris brièvement ta situation et nous te proposerons des invocations et adhkar adaptés."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tulis singkat situasimu, lalu kami akan menampilkan saran doa dan zikir yang sesuai."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tulis ringkas situasi anda, kemudian kami akan tunjukkan cadangan doa dan zikir yang sesuai."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кратко опишите свою ситуацию, и мы покажем подходящие дуа и зикры."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durumunu kısaca yaz, sana uygun dua ve zikir önerileri gösterelim."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اپنی صورتحال مختصراً لکھیں، ہم آپ کے لیے مناسب دعا اور ذکر کی تجاویز دکھائیں گے۔"
          }
        }
      }
    },
