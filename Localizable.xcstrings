    "rabia_intro_ask_name" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كيف تحب أن أخاطبك؟"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie möchtest du, dass ich dich anspreche?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How would you like me to address you?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Cómo te gustaría que me dirija a ti?"
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دوست داری چگونه صدایت کنم؟"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comment souhaitez-vous que je m'adresse à vous ?"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kamu ingin saya memanggilmu dengan sebutan apa?"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bagaimana anda mahu saya memanggil anda?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как вы хотите, чтобы я к вам обращалась?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sana nasıl hitap etmemi istersin?"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آپ چاہتے ہیں میں آپ کو کیسے مخاطب کروں؟"
          }
        }
      }
    },
    "rabia_intro_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "السلام عليكم. أنا رابعة. يمكننا التحدث عمّا يثقل قلبك أو يشغل بالك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Friede sei mit dir. Ich bin Rabia. Wir können über alles sprechen, was dein Herz oder deinen Kopf beschäftigt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Peace be upon you. I am Rabia. We can talk about whatever is weighing on your heart or mind."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La paz sea contigo. Soy Rabia. Podemos hablar de lo que te pese en el corazón o en la mente."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "السلام علیکم. من رابیا هستم. می‌توانیم درباره هر چیزی که دل یا ذهنت را درگیر کرده صحبت کنیم."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Que la paix soit sur toi. Je suis Rabia. Nous pouvons parler de tout ce qui pèse sur ton cœur ou ton esprit."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assalamu'alaikum. Saya Rabia. Kita bisa membicarakan apa pun yang memberatkan hati atau pikiranmu."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assalamualaikum. Saya Rabia. Kita boleh berbual tentang apa sahaja yang membebankan hati atau fikiran anda."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Мир тебе. Я Рабия. Мы можем поговорить о том, что тревожит твое сердце или мысли."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selâmün aleyküm. Ben Rabia. İçini yoran ya da aklına takılan ne varsa konuşabiliriz."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "السلام علیکم۔ میں رابعہ ہوں۔ جو بھی بات آپ کے دل یا ذہن پر بوجھ ہو، ہم اس پر بات کر سکتے ہیں۔"
          }
        }
      }
    },
    "rabia_intro_option_dhikr" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إن رغبت، يمكنني اقتراح ذكر مناسب."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du möchtest, kann ich einen passenden Dhikr vorschlagen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you want, I can suggest a suitable dhikr practice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si quieres, puedo sugerir un dhikr adecuado."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اگر بخواهی، می‌توانم ذکر مناسبی پیشنهاد دهم."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous le souhaitez, je peux proposer un dhikr adapté."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika kamu mau, saya bisa menyarankan dzikir yang sesuai."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika anda mahu, saya boleh cadangkan zikir yang sesuai."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если хотите, я могу предложить подходящий зикр."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İstersen uygun bir zikir önerisi sunabilirim."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اگر آپ چاہیں تو میں مناسب ذکر تجویز کر سکتی ہوں۔"
          }
        }
      }
    },
    "rabia_intro_option_support" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إن رغبت، يمكننا فقط التحدث؛ أنا هنا لأستمع."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du möchtest, können wir einfach reden; ich höre dir zu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you want, we can simply talk; I am here to listen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si quieres, simplemente podemos hablar; estoy aquí para escucharte."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اگر بخواهی، می‌توانیم فقط صحبت کنیم؛ من اینجا هستم تا گوش بدهم."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous le souhaitez, nous pouvons simplement parler ; je suis là pour vous écouter."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika kamu mau, kita bisa sekadar berbicara; saya siap mendengarkan."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika anda mahu, kita boleh berbual sahaja; saya sedia mendengar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если хотите, мы можем просто поговорить — я готова вас выслушать."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İstersen sadece konuşabiliriz; seni dinlerim."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اگر آپ چاہیں تو ہم صرف بات کر سکتے ہیں؛ میں آپ کی بات سننے کے لیے ہوں۔"
          }
        }
      }
    },
    "rabia_intro_option_topics" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إن رغبت، يمكنني شرح أي موضوع باختصار ووضوح."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du möchtest, kann ich ein Thema kurz und klar erklären."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you want, I can explain a topic briefly and clearly."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si quieres, puedo explicar un tema de forma breve y clara."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اگر بخواهی، می‌توانم یک موضوع را کوتاه و روشن توضیح بدهم."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous le souhaitez, je peux expliquer un sujet de manière brève et claire."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika kamu mau, saya bisa menjelaskan topik secara singkat dan jelas."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika anda mahu, saya boleh terangkan sesuatu topik dengan ringkas dan jelas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если хотите, я могу объяснить тему коротко и понятно."
          }
        },
        "tr" : {
