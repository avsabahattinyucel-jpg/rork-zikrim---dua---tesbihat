    "onboarding_page_premium_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "افتح تجربة بلا إعلانات وإحصاءات متقدمة وويدجت ومزامنة سحابية مع بريميوم الشهري أو السنوي."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schalte mit monatlichem oder jährlichem Premium ein werbefreies Erlebnis, erweiterte Statistiken, Widgets und Cloud-Sync frei."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unlock an ad-free experience, advanced statistics, widgets, and cloud sync with monthly or yearly Premium."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloquea una experiencia sin anuncios, estadísticas avanzadas, widgets y sincronización en la nube con Premium mensual o anual."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "با پریمیوم ماهانه یا سالانه، تجربه‌ای بدون تبلیغ، آمار پیشرفته، ویجت‌ها و همگام‌سازی ابری را فعال کن."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Débloquez une expérience sans publicité, des statistiques avancées, des widgets et la synchronisation cloud avec Premium mensuel ou annuel."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka pengalaman bebas iklan, statistik lanjutan, widget, dan sinkronisasi cloud dengan Premium bulanan atau tahunan."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka pengalaman tanpa iklan, statistik lanjutan, widget dan penyegerakan awan dengan Premium bulanan atau tahunan."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Откройте доступ к версии без рекламы, расширенной статистике, виджетам и облачной синхронизации с месячным или годовым Premium."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aylık ₺79 veya yıllık ₺799 ile reklamsız kullanım, gelişmiş istatistik, widget ve bulut senkronizasyonunu açın."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ماہانہ یا سالانہ پریمیم کے ساتھ بغیر اشتہار تجربہ، جدید شماریات، ویجٹس اور کلاؤڈ سنک حاصل کریں۔"
          }
        }
      }
    },
