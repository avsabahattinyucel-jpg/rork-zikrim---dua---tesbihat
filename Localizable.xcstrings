            "state" : "translated",
            "value" : "Confirma tu identidad para continuar eliminando esta cuenta."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "برای ادامه حذف این حساب، لطفاً هویت خود را تأیید کنید."
