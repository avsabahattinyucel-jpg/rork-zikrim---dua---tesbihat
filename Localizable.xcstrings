    "paywall_compliance_disclosure_manage" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكنك إدارة اشتراكك أو إلغاؤه من إعدادات حساب App Store بعد الشراء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach dem Kauf kannst du dein Abo in den App-Store-Kontoeinstellungen verwalten oder kündigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
