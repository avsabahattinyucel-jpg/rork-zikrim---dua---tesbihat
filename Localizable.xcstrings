            "value" : "يتم تحصيل الدفع من حساب Apple الخاص بك عند تأكيد الشراء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Zahlung wird bei Bestätigung des Kaufs deinem Apple-Konto belastet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Payment is charged to your Apple Account at confirmation of purchase."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El pago se carga a tu cuenta de Apple al confirmar la compra."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "پرداخت هنگام تأیید خرید به حساب Apple شما اعمال می‌شود."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le paiement est facturé sur votre compte Apple au moment de la confirmation de l’achat."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pembayaran dibebankan ke Akun Apple Anda saat pembelian dikonfirmasi."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bayaran akan dikenakan pada Akaun Apple anda semasa pembelian disahkan."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оплата списывается с вашей учётной записи Apple при подтверждении покупки."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
