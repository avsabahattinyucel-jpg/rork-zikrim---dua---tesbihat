        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ты завершил сегодняшний зикр. Отлично."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bugünkü zikrini tamamladın, tebrikler."
