    "quran_audio.premium_offline_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الاستماع دون اتصال متاح مع Premium.\nيمكنك تنزيل السور كاملة على جهازك والاستماع إليها دون اتصال بالإنترنت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Offline-Hören ist mit Premium verfügbar.\nDu kannst ganze Suren auf dein Gerät laden und ohne Internetverbindung anhören."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Offline listening is available with Premium.\nYou can download full surahs to your device and listen without an internet connection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La escucha sin conexión está disponible con Premium.\nPuedes descargar suras completas en tu dispositivo y escucharlas sin conexión a internet."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شنیدن آفلاین با Premium ارائه می‌شود.\nمی‌توانی سوره‌های کامل را روی دستگاهت دانلود کنی و بدون اینترنت گوش بدهی."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’écoute hors ligne est disponible avec Premium.\nVous pouvez télécharger des sourates complètes sur votre appareil et les écouter sans connexion Internet."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dengarkan offline tersedia dengan Premium.\nAnda dapat mengunduh surah lengkap ke perangkat dan mendengarkannya tanpa koneksi internet."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dengar luar talian tersedia dengan Premium.\nAnda boleh memuat turun surah penuh ke peranti dan mendengarnya tanpa sambungan internet."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Офлайн-прослушивание доступно с Premium.\nВы можете скачать полные суры на устройство и слушать их без интернета."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Çevrimdışı dinleme Premium ile sunulur.\nSurelerin tamamını cihazına indirip internet olmadan dinleyebilirsin."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آف لائن سماعت Premium کے ساتھ دستیاب ہے۔\nآپ مکمل سورتیں اپنے آلے پر ڈاؤن لوڈ کر کے انٹرنیٹ کے بغیر سن سکتے ہیں۔"
          }
        }
      }
    },
