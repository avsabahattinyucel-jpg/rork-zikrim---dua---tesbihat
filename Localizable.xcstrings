    "religious_ramazan_bayrami_worship" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُستحب صلاة العيد وصلة الرحم وإدخال السرور والصدقة في هذا اليوم المبارك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eid-Gebet, Familienbesuche, Versohnung und Wohltatigkeit machen diesen Tag gesegnet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eid prayer, family visits, reconciliation, and charity make the day blessed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La oración del Eid, las visitas familiares, la reconciliación y la caridad bendicen este día."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نماز عيد، ديدار خانواده، آشتي و صدقه، اين روز را پربركت مي‌كند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La priere de l’Eid, les visites familiales, la reconciliation et la charite rendent cette journee benie."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salat Id, silaturahmi keluarga, saling memaafkan, dan sedekah menjadikan hari ini penuh berkah."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solat Aidilfitri, ziarah keluarga, berdamai dan bersedekah menjadikan hari ini penuh berkat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Праздничная молитва, семейные визиты, примирение и милостыня делают этот день благословенным."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bayram namazı, aile ziyareti, gönül alma ve sadaka ile günü bereketlendirmek güzel olur."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عید کی نماز، اہلِ خانہ سے ملاقات، صلح اور صدقہ اس دن کو بابرکت بناتے ہیں۔"
          }
        }
      }
    },
    "religious_regaib_kandili_dua" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اللهم وجّه قلبي إلى الخير، وزيّن نيتي، ولا تحرمني رحمتك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, leite mein Herz zum Guten, verschonere meine Absicht und entziehe mir nicht Deine Barmherzigkeit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, guide my heart to goodness, beautify my intention, and do not deprive me of Your mercy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oh Allah, guía mi corazón al bien, embellece mi intención y no me prives de Tu misericordia."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خدايا، دلم را به سوي خير هدايت كن، نيتم را زيبا گردان و مرا از رحمتت محروم مكن."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, guide mon coeur vers le bien, embellis mon intention et ne me prive pas de Ta misericorde."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, tuntun hatiku kepada kebaikan, indahkan niatku, dan jangan jauhkan aku dari rahmat-Mu."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, bimbing hatiku kepada kebaikan, indahkan niatku, dan jangan jauhkan aku daripada rahmat-Mu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "О Аллах, направь мое сердце к благу, укрась мое намерение и не лишай меня Своей милости."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allah’ım kalbimi hayra yönelt, niyetimi güzelleştir ve beni rahmetinden ayırma."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اے اللہ، میرے دل کو خیر کی طرف رہنمائی دے، میری نیت کو خوبصورت بنا اور مجھے اپنی رحمت سے محروم نہ فرما۔"
          }
        }
      }
    },
    "religious_regaib_kandili_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ليلة الرغائب"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regaib-Nacht"
          }
        },
        "en" : {
