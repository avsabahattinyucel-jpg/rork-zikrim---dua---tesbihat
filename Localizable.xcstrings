        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apa yang bisa saya lakukan hari itu?"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apa yang boleh saya lakukan pada hari itu?"
