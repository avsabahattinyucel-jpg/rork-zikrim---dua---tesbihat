    "smart_body_completion_celebration_alt_1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تقدّم جميل، نسأل الله قبول سعيك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wunderbarer Fortschritt - möge deine Muhe angenommen werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Great progress—may your effort be accepted."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buen progreso; que tu esfuerzo sea aceptado."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "پيشرفت زيبايي است؛ خدا تلاشت را قبول كند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beau progres ; qu’Allah accepte ton effort."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perkembangan yang baik, semoga amalmu diterima."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kemajuan yang baik, semoga usahamu diterima."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Хороший прогресс - пусть твой труд будет принят."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Harika ilerledin, emeğin kabul olsun."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بہت اچھا پيش رفت ہے، اللہ تمہاری کوشش قبول فرمائے۔"
          }
        }
      }
    },
    "smart_body_completion_celebration_alt_2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أتممت ذكر اليوم، أحسنت."
