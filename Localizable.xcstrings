          "stringUnit" : {
            "state" : "translated",
            "value" : "ڈاؤن لوڈ کی گئی سورتیں آپ کے آلے میں محفوظ ہوتی ہیں اور اسٹوریج استعمال کرتی ہیں۔"
          }
