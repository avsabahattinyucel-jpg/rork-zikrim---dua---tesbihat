    "dhikr_motivation_complete" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ما شاء الله، أكملت ذكر اليوم. تقبّل الله."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MashaAllah, du hast das heutige Dhikr vollendet. Möge Allah es annehmen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MashaAllah, you completed today’s dhikr. May Allah accept it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mashallah, completaste el dhikr de hoy. Que Allah lo acepte."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ماشاءالله، ذکر امروزت را کامل کردی. خداوند قبول کند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MashaAllah, tu as terminé le dhikr d’aujourd’hui. Qu’Allah l’accepte."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MashaAllah, kamu menyelesaikan dzikir hari ini. Semoga Allah menerimanya."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MashaAllah, kamu telah melengkapkan zikir hari ini. Semoga Allah menerimanya."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "МашаАллах, ты завершил сегодняшний зикр. Пусть Аллах примет."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maşallah, bugünkü zikrini tamamladın. Allah kabul etsin."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ماشاءاللہ، تم نے آج کا ذکر مکمل کر لیا۔ اللہ قبول فرمائے۔"
          }
        }
      }
    },
    "dhikr_motivation_mid" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ما شاء الله، تواصل بثبات. بضع تكرارات أخرى ستجلب السكينة لقلبك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MashaAllah, du bleibst dran. Noch ein paar Wiederholungen bringen Ruhe ins Herz."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MashaAllah, you’re keeping a steady pace. A few more repetitions will bring calm to your heart."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mashallah, mantienes el ritmo. Unas repeticiones más traerán calma a tu corazón."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ماشاءالله، با نظم ادامه می دهی. چند تکرار دیگر آرامش به دلت می دهد."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MashaAllah, tu continues régulièrement. Quelques répétitions de plus apporteront de la sérénité."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MashaAllah, kamu terus konsisten. Beberapa kali lagi akan menenangkan hati."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MashaAllah, kamu terus konsisten. Beberapa ulangan lagi akan menenangkan hati."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "МашаАллах, ты идешь ровно. Ещё несколько повторений принесут спокойствие сердцу."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maşallah, düzenli devam ediyorsun. Birkaç tekrar daha kalbine ferahlık verecek."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ماشاءاللہ، تم باقاعدگی سے جاری رکھے ہوئے ہو۔ چند تکرار اور دل کو سکون دیں گے۔"
          }
        }
      }
    },
    "dhikr_motivation_near" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أحسنت، بقي القليل لإكمال ذكر اليوم!"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Großartig! Es fehlt nur noch wenig, um das heutige Dhikr abzuschließen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You’re doing great—just a little left to complete today’s dhikr!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Vas genial! Falta muy poco para completar el dhikr de hoy."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عالی پیش می روی—فقط کمی تا تکمیل ذکر امروز مانده است!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu avances très bien—il ne reste qu’un peu pour terminer le dhikr d’aujourd’hui."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kamu hebat—tinggal sedikit lagi untuk menyelesaikan dzikir hari ini!"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kamu hebat—tinggal sedikit lagi untuk melengkapkan zikir hari ini!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Отлично! Осталось совсем немного, чтобы завершить сегодняшний зикр."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Harika gidiyorsun, bugünkü zikirlerini tamamlamaya çok az kaldı!"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم بہت اچھا کر رہے ہو—آج کے ذکر کو مکمل کرنے میں بس تھوڑا سا رہ گیا ہے!"
          }
        }
      }
    },
    "dhikr_motivation_start" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بسم الله، بدأت اليوم بداية جميلة. الخطوات الصغيرة مهمة أيضًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bismillah, du hast heute einen schönen Anfang gemacht. Auch kleine Schritte zählen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bismillah, you made a beautiful start today. Small steps matter too."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bismillah, hoy has empezado muy bien. Los pequeños pasos también cuentan."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بسم الله، امروز شروع خوبی داشتی. قدم های کوچک هم ارزشمندند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bismillah, tu as bien commencé aujourd’hui. Les petits pas comptent aussi."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bismillah, kamu memulai dengan baik hari ini. Langkah kecil juga berarti."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bismillah, hari ini kamu bermula dengan baik. Langkah kecil juga penting."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Бисмиллях, сегодня ты хорошо начал. Маленькие шаги тоже важны."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bismillah, bugün güzel bir başlangıç yaptın. Küçük adımlar da çok kıymetli."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بسم اللہ، آج تم نے اچھی شروعات کی۔ چھوٹے قدم بھی قیمتی ہیں۔"
          }
        }
      }
    },
