        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setelah pembelian, Anda dapat mengelola atau membatalkan langganan di pengaturan akun App Store."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selepas pembelian, anda boleh mengurus atau membatalkan langganan dalam tetapan akaun App Store."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "После покупки вы можете управлять подпиской или отменить её в настройках учётной записи App Store."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satın alma sonrası aboneliğinizi App Store hesap ayarlarından yönetebilir veya iptal edebilirsiniz."
