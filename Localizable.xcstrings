        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika tetapan Sistem dipilih, aplikasi akan mengikut paparan cerah/gelap iPhone."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если выбран системный режим, приложение следует светлой/тёмной теме iPhone."
