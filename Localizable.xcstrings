    "zikrim_gunluk_dua_ve_zikir_pratigini_duzenli_sekilde_takip_etmenizi_saglayan_bir" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zikrim هو تطبيق يساعدك على متابعة ممارسات الدعاء والذكر اليومية بانتظام."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zikrim ist eine App, mit der du deine tägliche Dua- und Dhikr-Praxis regelmäßig verfolgen kannst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zikrim is an app that helps you regularly track your daily dua and dhikr practice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zikrim es una aplicación que te ayuda a seguir regularmente tu práctica diaria de du'a y dhikr."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zikrim برنامه‌ای است که به شما کمک می‌کند تمرین روزانه دعا و ذکر خود را منظم پیگیری کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zikrim est une application qui vous aide à suivre régulièrement votre pratique quotidienne de du'a et de dhikr."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zikrim adalah aplikasi yang membantu Anda melacak praktik doa dan dzikir harian secara teratur."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zikrim ialah aplikasi yang membantu anda menjejak amalan doa dan zikir harian secara berkala."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zikrim — приложение, помогающее регулярно отслеживать ежедневную практику дуа и зикра."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zikrim, günlük dua ve zikir pratiğini düzenli şekilde takip etmenizi sağlayan bir uygulamadır."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zikrim ایک ایپ ہے جو آپ کو روزانہ دعا اور ذکر کی مشق باقاعدگی سے ٹریک کرنے میں مدد دیتی ہے۔"
          }
        }
      }
    },
