        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اگر تنظیم سیستم انتخاب شود، برنامه از حالت روشن/تیره آیفون پیروی می‌کند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si le réglage Système est sélectionné, l’application suit l’apparence clair/sombre de l’iPhone."
