    "premium_paywall_feature_audio_detail" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استمع إلى السور في أجواء هادئة وحافظ على إيقاع عبادتك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Höre Suren in ruhiger Atmosphäre und bewahre deinen spirituellen Rhythmus."
          }
