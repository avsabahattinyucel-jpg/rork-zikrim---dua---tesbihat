    "tema_sadece_sekme_rengini_degil_kartlar_ve_yuzey_tonlarini_da_etkiler" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "السمة لا تؤثر فقط على لون التبويب، بل أيضًا على البطاقات ودرجات الأسطح."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Thema beeinflusst nicht nur die Tab-Farbe, sondern auch Karten und Oberflächentöne."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Theme affects not only tab color, but also cards and surface tones."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El tema no solo afecta el color de las pestañas, sino también las tarjetas y tonos de superficie."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم فقط رنگ تب را تغییر نمی‌دهد، بلکه روی کارت‌ها و تون سطوح هم اثر می‌گذارد."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le thème n’affecte pas seulement la couleur des onglets, mais aussi les cartes et tons de surface."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tema tidak hanya memengaruhi warna tab, tetapi juga kartu dan nuansa permukaan."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tema bukan sahaja mempengaruhi warna tab, tetapi juga kad dan tona permukaan."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тема влияет не только на цвет вкладок, но и на карточки и оттенки поверхностей."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tema sadece sekme rengini değil, kartlar ve yüzey tonlarını da etkiler."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تھیم صرف ٹیب کے رنگ کو نہیں بلکہ کارڈز اور سطحی رنگوں کو بھی متاثر کرتی ہے۔"
          }
        }
      }
    },
