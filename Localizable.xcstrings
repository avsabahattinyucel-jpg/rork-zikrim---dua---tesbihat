    "religious_berat_kandili_worship" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستحب الإكثار من الاستغفار والتوبة، والسعي إلى إصلاح القلوب إن وُجدت خصومة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Viel Istighfar, Reue und Versohnung mit Menschen, die du verletzt hast, sind passend."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abundant istighfar, repentance, and reconciling with anyone you hurt are appropriate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es apropiado hacer mucho istighfar, arrepentirse y reconciliarse con quien hayas herido."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استغفار فراوان، توبه و آشتي با كسي كه آزرده‌اي، مناسب است."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un abondant istighfar, le repentir et la reconciliation avec ceux que tu as blesses conviennent bien."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perbanyak istighfar, taubat, dan berdamai dengan orang yang pernah Anda sakiti."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perbanyak istighfar, taubat, dan berdamai dengan sesiapa yang pernah anda sakiti."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уместны частый истигфар, покаяние и примирение с теми, кого ты обидел."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bol istiğfar, tövbe ve kırgın olduğun biri varsa gönül alma niyetiyle hareket etmek uygun olur."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کثرت سے استغفار، توبہ اور جسے تم نے دکھ پہنچایا ہو اُس سے صلح کرنا مناسب ہے۔"
          }
        }
      }
    },
    "religious_kadir_gecesi_dua" : {
      "extractionState" : "manual",
      "localizations" : {
