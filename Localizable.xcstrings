    "theme_picker_helper_text" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند تغيير السمة، يتم تحديث شريط التنقل وشريط التبويب والبطاقات ومكوّنات Rabia معًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Ändern des Themas werden Navigationsleiste, Tab-Leiste, Karten und Rabia-Komponenten gemeinsam aktualisiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When the theme changes, the nav bar, tab bar, cards, and Rabia components update together."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al cambiar el tema, la barra de navegación, la barra de pestañas, las tarjetas y los componentes de Rabia se actualizan juntos."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "با تغییر تم، نوار ناوبری، نوار تب، کارت‌ها و بخش‌های ربیا با هم به‌روزرسانی می‌شوند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quand le thème change, la barre de navigation, la barre d’onglets, les cartes et les composants Rabia se mettent à jour ensemble."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saat tema berubah, navbar, tab bar, kartu, dan komponen Rabia ikut diperbarui."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apabila tema berubah, bar navigasi, bar tab, kad dan komponen Rabia dikemas kini bersama."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При смене темы вместе обновляются навбар, таб-бар, карточки и компоненты Rabia."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tema değiştiğinde navbar, tab bar, kartlar ve Rabia bileşenleri birlikte güncellenir."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تھیم بدلتے ہی نیویگیشن بار، ٹیب بار، کارڈز اور Rabia کے اجزا ایک ساتھ اپ ڈیٹ ہوتے ہیں۔"
          }
        }
      }
    },
