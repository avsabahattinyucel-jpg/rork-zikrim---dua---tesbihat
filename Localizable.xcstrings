    "acik_oldugunda_sure_dinleme_ekranindan_ciksaniz_bile_ses_arka_planda_devam_eder" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند التفعيل يستمر الصوت في الخلفية حتى بعد مغادرة شاشة السورة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, läuft die Wiedergabe im Hintergrund weiter, auch wenn du den Suren-Bildschirm verlässt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, audio keeps playing in the background even after leaving the surah screen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando está activado, el audio continúa en segundo plano incluso al salir de la pantalla de sura."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "در صورت فعال بودن، صدا حتی پس از خروج از صفحه سوره در پس‌زمینه ادامه می‌یابد."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque cette option est activée, le son continue en arrière-plan même après avoir quitté l’écran de la sourate."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saat aktif, audio tetap berjalan di latar belakang meski keluar dari layar surah."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apabila diaktifkan, audio terus dimainkan di latar belakang walaupun keluar dari skrin surah."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При включении звук продолжает воспроизводиться в фоне даже после выхода из экрана суры."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Açık olduğunda sure dinleme ekranından çıksanız bile ses arka planda devam eder."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فعال ہونے پر، سورہ اسکرین سے نکلنے کے بعد بھی آواز پس منظر میں چلتی رہے گی۔"
          }
        }
      }
    },
