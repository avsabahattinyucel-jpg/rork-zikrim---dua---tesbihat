    "o_gun_ne_yapabilirim" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ماذا يمكنني أن أفعل في ذلك اليوم؟"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was kann ich an diesem Tag tun?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What can I do that day?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Qué puedo hacer ese día?"
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آن روز چه کاری می‌توانم انجام دهم؟"
