    "onboarding_page_rabia_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابنِ روتين عبادة ثابتًا مع رابعة عبر الأدعية اليومية وتتبع الذكر والإرشاد الإسلامي والتذكيرات الذكية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Baue mit Rabia durch tägliche Duas, Dhikr-Tracking, islamische Begleitung und smarte Erinnerungen eine beständige Anbetungsroutine auf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Build a steady worship routine with Rabia through daily duas, dhikr tracking, Islamic guidance, and smart reminders."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construye una rutina espiritual constante con Rabia mediante duas diarias, seguimiento del dhikr, guía islámica y recordatorios inteligentes."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "با رابعه و با کمک دعاهای روزانه، پیگیری ذکر، راهنمایی اسلامی و یادآورهای هوشمند، یک برنامه عبادی پایدار بساز."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construisez une routine d’adoration stable avec Rabia grâce aux duas quotidiennes, au suivi du dhikr, à l’accompagnement islamique et aux rappels intelligents."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bangun rutinitas ibadah yang konsisten bersama Rabia melalui doa harian, pelacakan zikir, panduan Islami, dan pengingat cerdas."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bina rutin ibadah yang konsisten bersama Rabia melalui doa harian, penjejakan zikir, panduan Islam dan peringatan pintar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выстраивайте устойчивый ритм поклонения с Rabia через ежедневные дуа, отслеживание зикра, исламское наставление и умные напоминания."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rabia ile günlük dua, zikir takibi, İslami rehberlik ve akıllı hatırlatmalarla istikrarlı bir ibadet rutini oluşturun."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "روزانہ دعاؤں، ذکر ٹریکنگ، اسلامی رہنمائی اور اسمارٹ یاددہانیوں کے ساتھ Rabia کے ذریعے ایک مستقل عبادتی معمول بنائیں۔"
          }
        }
      }
    },
