        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn die Systemeinstellung gewählt ist, folgt die App dem hellen/dunklen Erscheinungsbild des iPhones."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If System setting is selected, the app follows the iPhone light/dark appearance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si está seleccionado Sistema, la app seguirá el modo claro/oscuro del iPhone."
