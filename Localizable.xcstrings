    "quran_audio.auto_advance_hint" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتقل تلقائيًا إلى الآية التالية عند انتهاء التشغيل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach Ende der Wiedergabe automatisch zum nächsten Vers wechseln."
