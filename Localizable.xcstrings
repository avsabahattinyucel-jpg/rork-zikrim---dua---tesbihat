    "rabia_chat_empty_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اكتب ما في قلبك، وسنبحث معًا عن جواب هادئ."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schreib, was dir am Herzen liegt, und wir suchen gemeinsam nach einer ruhigen Antwort."
