    "delete_account_backend_cleanup_failed" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعذر حذف بيانات حسابك. يرجى المحاولة مرة أخرى."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir konnten deine Kontodaten nicht entfernen. Bitte versuche es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We could not remove your account data. Please try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No pudimos eliminar los datos de tu cuenta. Inténtalo de nuevo."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نتوانستیم داده‌های حساب شما را حذف کنیم. لطفاً دوباره تلاش کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous n’avons pas pu supprimer les données de votre compte. Veuillez réessayer."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kami tidak dapat menghapus data akun Anda. Silakan coba lagi."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kami tidak dapat memadam data akaun anda. Sila cuba lagi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нам не удалось удалить данные вашего аккаунта. Попробуйте ещё раз."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hesap verilerini kaldıramadık. Lütfen tekrar dene."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ہم آپ کے اکاؤنٹ کا ڈیٹا حذف نہیں کر سکے۔ براہ کرم دوبارہ کوشش کریں۔"
          }
        }
      }
    },
    "delete_account_confirmation_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي حذف حسابك إلى إزالة بياناتك نهائيًا ولا يمكن التراجع عن ذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch das Löschen deines Kontos werden deine Daten dauerhaft entfernt und dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deleting your account will permanently remove your data and cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al eliminar tu cuenta, tus datos se borrarán de forma permanente y no se podrá deshacer."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حذف حساب شما داده‌هایتان را برای همیشه پاک می‌کند و قابل بازگشت نیست."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La suppression de votre compte effacera définitivement vos données et cette action est irréversible."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menghapus akun Anda akan menghapus data Anda secara permanen dan tidak dapat dibatalkan."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Memadam akaun anda akan memadam data anda secara kekal dan tidak boleh dibatalkan."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Удаление аккаунта навсегда удалит ваши данные, и это действие нельзя отменить."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hesabını silmek verilerini kalıcı olarak kaldırır ve bu işlem geri alınamaz."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آپ کا اکاؤنٹ حذف کرنے سے آپ کا ڈیٹا مستقل طور پر مٹ جائے گا اور اسے واپس نہیں لایا جا سکتا۔"
          }
        }
      }
    },
