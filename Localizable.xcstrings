    "rabia_watch_ad_prompt_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج المستخدمون المجانيون إلى مشاهدة إعلان قبل سؤال Rabia. هل تريد مشاهدة إعلان الآن؟"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutzer im Gratis-Tarif müssen vor einer Frage an Rabia eine Anzeige ansehen. Möchten Sie jetzt eine Anzeige ansehen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Free users need to watch an ad before asking Rabia a question. Would you like to watch an ad now?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los usuarios gratuitos deben ver un anuncio antes de preguntar a Rabia. ¿Quieres ver un anuncio ahora?"
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کاربران رایگان پیش از پرسیدن از ربیا باید یک تبلیغ ببینند. می‌خواهید الآن تبلیغ را ببینید؟"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les utilisateurs gratuits doivent regarder une publicité avant de poser une question à Rabia. Voulez-vous regarder une publicité maintenant ?"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pengguna gratis perlu menonton iklan sebelum bertanya kepada Rabia. Ingin menonton iklan sekarang?"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pengguna percuma perlu menonton iklan sebelum bertanya kepada Rabia. Mahu tonton iklan sekarang?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Бесплатным пользователям нужно посмотреть рекламу перед вопросом к Rabia. Хотите посмотреть рекламу сейчас?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ücretsiz kullanımda Rabia'ya soru sormak için reklam izlemeniz gerekir. Şimdi reklam izlemek ister misiniz?"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مفت صارفین کو Rabia سے سوال پوچھنے سے پہلے اشتہار دیکھنا ہوگا۔ کیا آپ ابھی اشتہار دیکھنا چاہتے ہیں؟"
          }
        }
      }
    },
