    "religious_berat_kandili_dua" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اللهم اغفر ذنوبي، وطهّر قلبي، وافتح لي أبواب العفو."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, vergib mir meine Sunden, reinige mein Herz und offne mir die Tore der Vergebung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, forgive my sins, purify my heart, and open for me the gates of pardon."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oh Allah, perdona mis pecados, purifica mi corazón y ábreme las puertas del perdón."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خدايا، گناهانم را ببخش، دلم را پاك كن و درهاي آمرزش را به رويم بگشا."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, pardonne mes peches, purifie mon coeur et ouvre-moi les portes du pardon."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, ampunilah dosaku, sucikan hatiku, dan bukakan bagiku pintu ampunan-Mu."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, ampunkan dosaku, sucikan hatiku, dan bukakan untukku pintu keampunan-Mu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "О Аллах, прости мои грехи, очисти мое сердце и открой мне врата прощения."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allah’ım günahlarımı bağışla, kalbimi temizle ve bana af kapılarını aç."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اے اللہ، میرے گناہ معاف فرما، میرے دل کو پاک کر اور میرے لیے بخشش کے دروازے کھول دے۔"
          }
        }
      }
    },
