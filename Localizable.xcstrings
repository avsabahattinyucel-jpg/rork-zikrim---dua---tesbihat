          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eid al-Adha"
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عيد قربان"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eid al-Adha"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Idul Adha"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aidiladha"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ид аль-Адха"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kurban Bayramı"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عيد الاضحی"
          }
        }
      }
    },
    "religious_kurban_bayrami_worship" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُؤكَّد صلاة العيد والأضحية لمن استطاع ورعاية المحتاجين."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eid-Gebet, Opfergabe, wenn moglich, und die Sorge fur Bedurftige stehen im Mittelpunkt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eid prayer, sacrifice if able, and caring for those in need are emphasized."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se destacan la oración del Eid, el sacrificio si es posible y el cuidado de quienes lo necesitan."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نماز عيد، قرباني در صورت توان و رسيدگي به نيازمندان برجسته است."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La priere de l’Eid, le sacrifice si possible et l’attention aux personnes dans le besoin sont mis en avant."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salat Id, berkurban jika mampu, dan memperhatikan yang membutuhkan sangat dianjurkan."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solat Aidiladha, ibadah korban jika mampu, dan menjaga golongan memerlukan sangat dititikberatkan."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подчеркиваются праздничная молитва, жертвоприношение при возможности и забота о нуждающихся."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bayram namazı, imkan varsa kurban ibadeti ve ihtiyaç sahiplerini gözetmek öne çıkar."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عید کی نماز، استطاعت ہو تو قربانی، اور ضرورت مندوں کی خبر گیری اس دن کی نمایاں عبادات ہیں۔"
          }
        }
      }
    },
    "religious_mevlid_kandili_dua" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اللهم ارزقنا حياةً قريبةً من سنة رسول الله ﷺ."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, gewahre uns ein Leben nah an der Sunnah des Gesandten Allahs."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, grant us a life close to the Sunnah of the Messenger of Allah."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oh Allah, concédenos una vida cercana a la Sunnah del Mensajero de Allah."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خدايا، زندگي‌اي نزديك به سنت رسول الله به ما عطا كن."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, accorde-nous une vie proche de la Sunna du Messager d’Allah."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, anugerahkan kepada kami kehidupan yang dekat dengan sunnah Rasulullah."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, kurniakan kepada kami kehidupan yang dekat dengan sunnah Rasulullah."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "О Аллах, даруй нам жизнь, близкую к сунне Посланника Аллаха."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allah’ım Resulullah’ın sünnetine yakın bir hayat yaşamayı bize nasip et."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اے اللہ، ہمیں رسول اللہ ﷺ کی سنت کے قریب زندگی عطا فرما۔"
          }
        }
      }
    },
    "religious_mevlid_kandili_title" : {
