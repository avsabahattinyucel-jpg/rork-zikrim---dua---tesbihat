    "amacimiz_tesbih_rehber_icerikler_namaz_vakitleri_ve_kisisel_takip_araclariyla_ib" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هدفنا دعم عبادتك بالتسبيح، والمحتوى الإرشادي، ومواقيت الصلاة، وأدوات المتابعة الشخصية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unser Ziel ist es, deine Ibadah mit Tasbih, Leitfaden-Inhalten, Gebetszeiten und persönlichen Tracking-Tools zu unterstützen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Our goal is to support your worship with tasbih, guide content, prayer times, and personal tracking tools."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuestro objetivo es apoyar tu adoración con tasbih, contenido de guía, horarios de oración y herramientas de seguimiento personal."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هدف ما پشتیبانی از عبادت شما با تسبیح، محتوای راهنما، اوقات نماز و ابزارهای پیگیری شخصی است."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notre objectif est de soutenir votre adoration avec le tasbih, des contenus de guide, les horaires de prière et des outils de suivi personnel."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tujuan kami adalah mendukung ibadah Anda dengan tasbih, konten panduan, waktu salat, dan alat pelacakan pribadi."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Matlamat kami ialah menyokong ibadah anda dengan tasbih, kandungan panduan, waktu solat dan alat penjejakan peribadi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Наша цель — поддерживать ваше поклонение с помощью тасбиха, справочных материалов, времени намаза и личных инструментов отслеживания."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amacımız tesbih, rehber içerikler, namaz vakitleri ve kişisel takip araçlarıyla ibadetinizi desteklemek."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ہمارا مقصد تسبیح، رہنمائی مواد، اوقاتِ نماز اور ذاتی ٹریکنگ ٹولز کے ذریعے عبادت میں مدد دینا ہے۔"
          }
        }
      }
    },
    "ana_ekranda_bos_bir_alana_uzun_basin_duzenle_menusunden_zikrim_widget_ini_ekleyi" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط مطولًا على مساحة فارغة في الشاشة الرئيسية، ثم أضف أداة Zikrim من قائمة التعديل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halte auf dem Home-Bildschirm eine freie Stelle gedrückt. Füge das Zikrim-Widget über das Bearbeiten-Menü hinzu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Long-press an empty area on the home screen. Add the Zikrim widget from the Edit menu."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén pulsada una zona vacía de la pantalla de inicio. Añade el widget de Zikrim desde el menú Editar."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "روی فضای خالی صفحه اصلی لمس طولانی کنید و ویجت Zikrim را از منوی ویرایش اضافه کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maintenez appuyé un espace vide de l’écran d’accueil. Ajoutez le widget Zikrim depuis le menu Modifier."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekan lama area kosong di layar utama. Tambahkan widget Zikrim dari menu Edit."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekan lama kawasan kosong pada skrin utama. Tambah widget Zikrim dari menu Edit."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зажмите пустое место на главном экране. Добавьте виджет Zikrim из меню редактирования."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ana ekranda boş bir alana uzun basın. Düzenle menüsünden Zikrim widget'ını ekleyin."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ہوم اسکرین پر خالی جگہ کو دیر تک دبائیں۔ Edit مینو سے Zikrim ویجٹ شامل کریں۔"
          }
        }
      }
    },
