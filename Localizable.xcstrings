      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا تم اختيار إعداد النظام، فسيتبع التطبيق مظهر iPhone الفاتح/الداكن."
