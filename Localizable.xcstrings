    "onboarding_rabia_welcome_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "السلام عليكم، أنا رابعة. في هذا التطبيق سأرافقك خطوة بخطوة لتتابع ذكرك بانتظام، وتقوّي أدعيتك، وتواصل إيقاع عبادتك اليومية بسكينة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assalamu alaikum, ich bin Rabia. In dieser App begleite ich dich Schritt für Schritt, damit du deinen Dhikr regelmäßig verfolgst, deine Duas stärkst und deinen täglichen Rhythmus der Anbetung in Ruhe fortsetzt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assalamu alaikum, I am Rabia. In this app, I will guide you step by step so you can track your dhikr regularly, strengthen your duas, and continue your daily worship rhythm with peace."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As-salamu alaykum, soy Rabia. En esta app te acompañaré paso a paso para que sigas tu dhikr con constancia, fortalezcas tus duas y mantengas tu ritmo diario de adoración con serenidad."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "السلام علیکم، من رابعه هستم. در این برنامه قدم‌به‌قدم همراهت هستم تا ذکر خود را منظم دنبال کنی، دعاهایت را تقویت کنی و ریتم عبادی روزانه‌ات را با آرامش ادامه دهی."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assalamu alaikum, je suis Rabia. Dans cette app, je vous accompagnerai pas à pas pour suivre votre dhikr avec régularité, renforcer vos duas et poursuivre votre rythme quotidien d’adoration avec paix."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assalamu alaikum, saya Rabia. Di aplikasi ini saya akan mendampingi Anda langkah demi langkah agar dapat mengikuti zikir secara teratur, menguatkan doa, dan menjaga ritme ibadah harian dengan tenang."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assalamu alaikum, saya Rabia. Dalam aplikasi ini saya akan menemani anda langkah demi langkah agar anda dapat mengikuti zikir dengan teratur, menguatkan doa, dan meneruskan ritma ibadah harian dengan tenang."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ассаляму алейкум, я Rabia. В этом приложении я буду рядом шаг за шагом, чтобы вы регулярно вели зикр, укрепляли свои дуа и продолжали ежедневный ритм поклонения со спокойствием."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esselâmü aleyküm, ben Rabia. Bu uygulamada zikirlerini düzenli takip etmen, dualarını güçlendirmen ve günlük ibadet ritmini huzurla sürdürmen için sana adım adım eşlik edeceğim."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "السلام علیکم، میں Rabia ہوں۔ اس ایپ میں میں قدم بہ قدم آپ کی رہنمائی کروں گی تاکہ آپ باقاعدگی سے ذکر کریں، اپنی دعاؤں کو مضبوط کریں اور اپنے روزانہ کے عبادتی معمول کو سکون کے ساتھ جاری رکھیں۔"
          }
        }
      }
    },
