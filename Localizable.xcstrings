    "religious_mevlid_kandili_worship" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُستحب الإكثار من الصلاة على النبي وقراءة السيرة والتأمل في مكارم الأخلاق."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Viel Salawat, das Lesen der Sira und das Nachdenken uber edlen Charakter sind passend."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sending abundant salawat, reading the seerah, and reflecting on noble character are appropriate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es apropiado abundar en salawat, leer la sira y reflexionar sobre el noble carácter."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كثرت صلوات، خواندن سيره و تأمل در اخلاق نيكو مناسب است."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abonder en salawat, lire la sira et reflechir au noble caractere sont appropries."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Memperbanyak salawat, membaca sirah, dan merenungkan akhlak mulia sangat baik dilakukan."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Memperbanyak selawat, membaca sirah dan merenung tentang akhlak mulia sangat sesuai dilakukan."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уместны частые салаваты, чтение сиры и размышление о благородном нраве."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bol salavat getirmek, siyer okumak ve güzel ahlak üzerine tefekkür etmek uygun olur."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کثرت سے درود، سیرت کا مطالعہ اور اعلیٰ اخلاق پر غور مناسب ہے۔"
          }
        }
      }
    },
    "religious_mirac_kandili_dua" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اللهم قوِّ إيماني، وامنح قلبي السكينة، وأحيِ قلبي ببركة الصلاة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, stärke meinen Iman, schenke meinem Herzen Frieden und halte mich mit dem Segen des Gebets lebendig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, strengthen my faith, grant peace to my heart, and keep me alive with the blessing of prayer."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oh Allah, fortalece mi fe, concede paz a mi corazón y mantén viva mi alma con la bendición de la oración."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خدايا، ايمانم را استوار كن، به دلم آرامش بده و مرا با بركت نماز زنده نگه دار."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, renforce ma foi, accorde la paix a mon coeur et garde-moi vivant par la benediction de la priere."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, kuatkan imanku, berilah kedamaian pada hatiku, dan hidupkan diriku dengan keberkahan salat."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, kuatkan imanku, berikan ketenangan kepada hatiku, dan hidupkan jiwaku dengan keberkatan solat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "О Аллах, укрепи мою веру, даруй мир моему сердцу и оживи меня благословением молитвы."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allah’ım imanımı kuvvetlendir, kalbime huzur ver ve beni namazın bereketiyle diri tut."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اے اللہ، میرے ایمان کو مضبوط فرما، میرے دل کو سکون دے اور نماز کی برکت سے مجھے زندہ رکھ۔"
          }
        }
      }
    },
