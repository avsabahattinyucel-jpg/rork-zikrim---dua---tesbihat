    "religious_mirac_kandili_worship" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بعد العشاء، يُستحب الدعاء والصلاة على النبي وقراءة يسيرة من القرآن إن تيسر."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach Isha sind Dua, Salawat und wenn moglich eine kurze Quranrezitation wohltuend."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "After Isha, dua, salawat, and if possible a short recitation of the Qur’an are beneficial."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Después de Isha, la dua, los salawat y, si es posible, una breve recitación del Corán son beneficiosos."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "پس از عشا، دعا، صلوات و اگر ممكن باشد تلاوتي كوتاه از قرآن سودمند است."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apres Isha, la dua, les salawat et si possible une courte recitation du Coran sont benefiques."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selepas Isya, berdoa, berselawat, dan jika memungkinkan membaca Al-Qur’an sebentar sangat baik."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selepas Isyak, berdoa, berselawat dan jika mampu membaca al-Quran sebentar sangat baik."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "После Иша полезны дуа, салаваты и, если возможно, короткое чтение Корана."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yatsı sonrası dua, salavat ve imkan varsa kısa bir Kur’an tilaveti güzel olur."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عشاء کے بعد دعا، درود اور اگر ممکن ہو تو قرآن کی مختصر تلاوت بہت مفید ہے۔"
          }
        }
      }
    },
    "religious_ramazan_bayrami_dua" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اللهم تقبل صيامنا وعباداتنا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, nimm unser Fasten und unsere Anbetung an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, accept our fasting and worship."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oh Allah, acepta nuestro ayuno y nuestra adoración."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خدايا، روزه و عبادت ما را بپذير."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, accepte notre jeune et notre adoration."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, terimalah puasa dan ibadah kami."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, terimalah puasa dan ibadah kami."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "О Аллах, прими наш пост и наше поклонение."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allah’ım tuttuğumuz oruçları ve yaptığımız ibadetleri kabul eyle."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اے اللہ، ہمارے روزے اور عبادت کو قبول فرما۔"
          }
        }
      }
    },
    "religious_ramazan_bayrami_title" : {
