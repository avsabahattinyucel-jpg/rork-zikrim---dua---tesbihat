    "religious_today_worship" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكنك أن تعمّر يومك بذكرٍ ودعاءٍ وشكرٍ يسير."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kannst den heutigen Tag mit kurzem Dhikr, Dua und Dankbarkeit verbringen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can spend today with brief dhikr, dua, and gratitude."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puedes pasar hoy con dhikr breve, dua y gratitud."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "امروز را مي‌تواني با ذكري كوتاه، دعا و شكر سپري كني."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu peux passer cette journee avec un court dhikr, une dua et de la gratitude."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anda boleh melalui hari ini dengan zikir singkat, doa, dan rasa syukur."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anda boleh melalui hari ini dengan zikir ringkas, doa dan rasa syukur."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Этот день можно провести с коротким зикром, дуа и благодарностью."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bugünü kısa bir zikir, dua ve şükürle değerlendirebilirsin."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آج کا دن مختصر ذکر، دعا اور شکرگزاری کے ساتھ گزارا جا سکتا ہے۔"
          }
        }
      }
    },
