    "onboarding_page_dhikr_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدّد هدفًا، وتابع ذكرك بانتظام، واحفظ استمراريتك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setze dir ein Ziel, verfolge deinen Dhikr regelmäßig und bewahre deine Beständigkeit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set a goal, track your dhikr consistently, and protect your streak."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fija una meta, sigue tu dhikr con constancia y cuida tu continuidad."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "برای خود هدف بگذار، ذکر خود را منظم دنبال کن و استمرار معنوی‌ات را حفظ کن."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fixez un objectif, suivez votre dhikr avec régularité et préservez votre constance."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tetapkan tujuan, ikuti zikir Anda secara teratur, dan jaga konsistensinya."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tetapkan sasaran, ikuti zikir anda dengan teratur, dan kekalkan konsistensinya."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Поставьте цель, регулярно отслеживайте зикр и сохраняйте постоянство."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hedef belirleyin, zikrinizi düzenli takip edin ve serinizi koruyun."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ایک ہدف مقرر کریں، اپنے ذکر کو باقاعدگی سے جاری رکھیں اور تسلسل برقرار رکھیں۔"
          }
        }
      }
    },
