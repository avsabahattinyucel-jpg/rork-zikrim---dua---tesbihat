        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You completed today’s dhikr. Well done."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Has completado el dhikr de hoy. Muy bien."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ذكر امروزت را كامل كردي. احسنت."
