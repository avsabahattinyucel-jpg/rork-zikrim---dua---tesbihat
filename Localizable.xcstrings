    "religious_regaib_kandili_worship" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بعد صلاة العشاء، من المناسب ركعتان نافلة مع الاستغفار وتأمل قصير."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach dem Abendgebet sind zwei Rakaat freiwilliges Gebet, Istighfar und eine kurze Besinnung wohltuend."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "After the evening prayer, two rakahs of voluntary prayer, istighfar, and brief reflection are beneficial."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Después de la oración del anochecer, dos rakats voluntarios, istighfar y una breve reflexión son apropiados."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "پس از نماز شام، دو ركعت نماز نافله، استغفار و اندكي تفكر مناسب است."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apres la priere du soir, deux rakaats surerogatoires, l’istighfar et une breve reflexion sont benefiques."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selepas salat Maghrib, dua rakaat sunnah, istighfar, dan renungan singkat sangat baik dilakukan."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selepas solat Maghrib, dua rakaat sunat, istighfar dan renungan ringkas sangat baik dilakukan."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "После вечерней молитвы полезны два ракаата нафиля, истигфар и короткое размышление."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Akşam namazından sonra iki rekat nafile namaz, istiğfar ve kısa bir tefekkür iyi olur."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نمازِ مغرب کے بعد دو رکعت نفل، استغفار اور مختصر غور و فکر بہت مناسب ہے۔"
          }
        }
      }
    },
    "religious_today_dua" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اللهم اجعل هذا اليوم خيرًا وبركةً وسكينةً."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, mache diesen Tag gut, gesegnet und friedvoll."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, make this day good, blessed, and peaceful."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oh Allah, haz que este día sea bueno, bendecido y sereno."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خدايا، اين روز را نيك، پربركت و آرام قرار بده."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, rends cette journee bonne, benie et paisible."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, jadikan hari ini baik, penuh berkah, dan tenang."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, jadikan hari ini baik, diberkati dan tenang."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "О Аллах, сделай этот день добрым, благословенным и спокойным."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allah’ım bugünü hayırlı, bereketli ve huzurlu eyle."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اے اللہ، آج کے دن کو اچھا، بابرکت اور پُرسکون بنا دے۔"
          }
        }
      }
    },
