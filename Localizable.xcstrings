    "religious_kadir_gecesi_worship" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قراءة القرآن والتسبيح وإحياء الليل بالعبادة -ولو قليلاً- أمر عظيم."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quranrezitation, Tasbih und auch eine kurze Nacht des Gottesdienstes sind sehr wertvoll."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reciting Qur’an, doing tasbih, and spending the night in worship, even briefly, is very precious."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recitar el Corán, hacer tasbih y dedicar aunque sea un poco de la noche a la adoración es muy valioso."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تلاوت قرآن، تسبيح و حتي اندكي عبادت در شب، بسيار ارزشمند است."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La recitation du Coran, le tasbih et meme un court temps d’adoration durant la nuit sont tres precieux."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Membaca Al-Qur’an, bertasbih, dan beribadah walau sebentar di malam ini sangat berharga."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Membaca al-Quran, bertasbih dan beribadah walaupun seketika pada malam ini sangat bernilai."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чтение Корана, тасбих и даже короткое поклонение ночью очень ценны."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kur’an okumak, tesbihat yapmak ve geceyi kısa da olsa ibadetle geçirmek çok kıymetlidir."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قرآن کی تلاوت، تسبیح اور رات میں تھوڑی سی عبادت بھی بہت قیمتی ہے۔"
          }
        }
      }
    },
    "religious_kurban_bayrami_dua" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اللهم تقبل منا التسليم، وارزقنا الإخلاص والبركة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, nimm unsere Hingabe an und schenke uns Aufrichtigkeit und Segen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, accept our submission and grant us sincerity and blessing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oh Allah, acepta nuestra entrega y concédenos sinceridad y bendición."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خدايا، تسليم ما را بپذير و به ما اخلاص و بركت عطا كن."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Allah, accepte notre soumission et accorde-nous sincerite et benediction."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, terimalah kepasrahan kami dan anugerahkan keikhlasan serta keberkahan."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya Allah, terimalah penyerahan kami dan kurniakan keikhlasan serta keberkatan."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "О Аллах, прими наше смирение и даруй нам искренность и благословение."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allah’ım teslimiyetimizi kabul eyle, bize ihlas ve bereket nasip et."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اے اللہ، ہماری فرماں برداری قبول فرما اور ہمیں اخلاص اور برکت عطا فرما۔"
          }
        }
      }
    },
    "religious_kurban_bayrami_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عيد الأضحى"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eid al-Adha"
          }
        },
        "en" : {
          "stringUnit" : {
