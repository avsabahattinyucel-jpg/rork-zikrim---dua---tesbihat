    "Telefonun üst kısmını altın işaretle aynı hizada tutun." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أبقِ الجزء العلوي من الهاتف بمحاذاة العلامة الذهبية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Richten Sie die Oberseite Ihres Telefons an der goldenen Markierung aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep the top of your phone aligned with the gold marker."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén la parte superior del teléfono alineada con la marca dorada."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بالای گوشی را با نشان طلایی هم‌راستا نگه دارید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gardez le haut de votre téléphone aligné avec le repère doré."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sejajarkan bagian atas ponsel dengan penanda emas."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pastikan bahagian atas telefon sejajar dengan penanda emas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Держите верхнюю часть телефона на одной линии с золотой меткой."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Telefonun üst kısmını altın işaretle aynı hizada tutun."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فون کے اوپری حصے کو سنہری نشان کے ساتھ برابر رکھیں۔"
          }
        }
      }
    },
