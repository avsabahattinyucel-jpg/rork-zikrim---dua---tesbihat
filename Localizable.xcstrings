    "onboarding_avlu_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابدأ يومك بالصلاة والذكر وتذكيرات هادئة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beginne deinen Tag mit Gebet, Dhikr und ruhigen Erinnerungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Begin your day with prayer, dhikr, and calm reminders."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empieza tu día con oración, dhikr y recordatorios serenos."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "روز خود را با دعا، ذکر و یادآورهای آرام آغاز کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Commencez votre journée avec la prière, le dhikr et des rappels apaisants."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mulailah hari Anda dengan doa, dhikr, dan pengingat yang menenangkan."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mulakan hari anda dengan doa, zikir dan peringatan yang menenangkan."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Начинайте день с молитвы, зикра и спокойных напоминаний."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gününüze dua, zikir ve huzurlu hatırlatmalarla başlayın."
          }
        },
        "ur" : {
