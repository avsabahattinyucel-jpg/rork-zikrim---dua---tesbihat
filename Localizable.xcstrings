    "buluttaki_veriler_mevcut_verilerinizin_uzerine_yazilacak_devam_etmek_istiyor_musunuz" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ستحل بيانات السحابة محل بياناتك الحالية. هل تريد المتابعة؟"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cloud-Daten überschreiben Ihre aktuellen Daten. Möchten Sie fortfahren?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cloud data will overwrite your current data. Do you want to continue?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los datos de la nube sobrescribirán tus datos actuales. ¿Quieres continuar?"
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "داده‌های ابری روی داده‌های فعلی شما بازنویسی می‌شوند. ادامه می‌دهید؟"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les données du cloud écraseront vos données actuelles. Voulez-vous continuer ?"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data cloud akan menimpa data Anda saat ini. Lanjutkan?"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data awan akan menimpa data semasa anda. Teruskan?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Данные из облака перезапишут текущие данные. Продолжить?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buluttaki veriler mevcut verilerinizin uzerine yazilacak. Devam etmek istiyor musunuz?"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کلاؤڈ ڈیٹا آپ کے موجودہ ڈیٹا پر لکھ دیا جائے گا۔ کیا آپ جاری رکھنا چاہتے ہیں؟"
          }
