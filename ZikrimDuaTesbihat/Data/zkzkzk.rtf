\outl0\strokewidth0 \strokec2 Kapsaml\uc0\u305  Dua ve Zikir Rehberi: Manevi \u350 ifa ve Korunma Veritaban\u305 \
\pard\pardeftab720\sa240\partightenfactor0

\f1\b0\fs24 \cf0 Bu dok\'fcman, klasik \uc0\u304 slami kaynaklar ve teknik veriler \u305 \u351 \u305 \u287 \u305 nda, dua ve zikrin teolojik zeminini pratik uygulama modelleriyle birle\u351 tiren bir bilgi mimarisi \'e7al\u305 \u351 mas\u305 d\u305 r.\
\pard\pardeftab720\sa298\partightenfactor0

\f0\b\fs36 \cf0 1. Giri\uc0\u351 : Dua ve Zikrin Mahiyeti ve \'d6nemi\
\pard\pardeftab720\sa240\partightenfactor0

\f1\b0\fs24 \cf0 Dua; l\'fcgatte ibadet etmek, yard\uc0\u305 m istemek ve Allah\'92a ra\u287 bet etmek manalar\u305 na gelirken; \u305 st\u305 lahta kulun acziyetini ikrar ederek sonsuz kudret sahibi olan Allah\'92a y\'f6nelmesidir.\
\pard\pardeftab720\sa240\partightenfactor0

\f0\b \cf0 Duan\uc0\u305 n Teolojik Nitelikleri:
\f1\b0 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls1\ilvl0
\f0\b \cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Bir \uc0\u304 tiraf:
\f1\b0  Dua, kulun kendi zay\uc0\u305 fl\u305 \u287 \u305 n\u305  (aczini) ve Allah\'92\u305 n mutlak g\'fcc\'fcn\'fc (Kadir) kabul etti\u287 i en samimi beyand\u305 r.\
\ls1\ilvl0
\f0\b \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Kulluk Bilinci:
\f1\b0  Hz. Peygamber (sas) "Dua ibadettir" ve "Dua ibadetin \'f6z\'fcd\'fcr" buyurarak, duay\uc0\u305  kulluk hiyerar\u351 isinin merkezine yerle\u351 tirmi\u351 tir.\
\ls1\ilvl0
\f0\b \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 \uc0\u350 \'fck\'fcr \u304 fadesi:
\f1\b0  K\'e2mil m\'fcmin, her ba\uc0\u351 ar\u305 y\u305  Allah\'92tan bilir; "Allah yard\u305 m etti" diyerek ba\u351 ar\u305 s\u305 n\u305  \u351 \'fckre d\'f6n\'fc\u351 t\'fcr\'fcr.\
\pard\pardeftab720\sa240\partightenfactor0

