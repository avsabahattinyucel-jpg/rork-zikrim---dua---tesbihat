\ls3\ilvl0
\f0\b \cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 1. Rek'at:
\f1\b0  F\'e2tiha s\'fbresinden sonra 3 defa \'c2yet\'fc'l-k\'fcrs\'ee okunur.\
\ls3\ilvl0
\f0\b \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 2, 3 ve 4. Rek'atlar:
\f1\b0  F\'e2tiha'dan sonra birer \uc0\u304 hlas, Felak ve N\'e2s s\'fbreleri okunur.\
\ls3\ilvl0
\f0\b \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Uygulama:
\f1\b0  Namaz sonunda Allah zikredilir, Peygamber (sas)'e salav\'e2t getirilir ve ard\uc0\u305 ndan H\'e2cet duas\u305  okunur.\
\pard\pardeftab720\sa240\partightenfactor0

