{
  "name": "diyk-dataset",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready crawler/parser/exporter for official public content from Diyanet Din Isleri Yuksek Kurulu.",
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "crawl": "tsx src/cli/crawl.ts",
    "parse": "tsx src/cli/parse.ts",
    "export": "tsx src/cli/export.ts",
    "publish:remote": "node ../scripts/publish_diyanet_remote_bundle.mjs",
    "refresh": "tsx src/cli/refresh.ts",
    "doctor": "tsx src/cli/doctor.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^4.5.3",
    "pino": "^9.6.0",
    "playwright": "^1.52.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "domhandler": "^5.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
