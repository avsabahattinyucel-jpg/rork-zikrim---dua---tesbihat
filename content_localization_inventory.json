  "json": {
    "ZikrimDuaVeTesbihat/Data/islamic_knowledge.json": {
      "count": 24,
      "items_sample": [
        {
          "field": "title",
          "value": "Namazın Yeri"
        },
        {
          "field": "summary",
          "value": "Namaz, kulun gün içinde Rabbi ile bağını tazeleyen temel ibadettir. Düzenli kılınması kalpte istikamet, hayatta disiplin ve ruhta sükunet oluşturur."
        },
        {
          "field": "title",
          "value": "Abdest ve Hazırlık"
        },
        {
          "field": "summary",
          "value": "Abdest, namaza ve bazı ibadetlere manevi hazırlıktır. Sadece bedeni değil, niyeti ve dikkati de toparlayan bir temizliktir."
        },
        {
          "field": "title",
          "value": "Orucun Hikmeti"
        },
        {
          "field": "summary",
          "value": "Oruç, sadece aç kalmak değil; nefsi eğitmek, sabrı güçlendirmek ve Allah'a karşı kulluk bilincini derinleştirmektir."
        },
        {
          "field": "title",
          "value": "Tevbe Kapısı"
        },
        {
          "field": "summary",
          "value": "Tevbe, günahı hafife almak değil; pişmanlık, yöneliş ve düzeltme niyetiyle Allah'a dönmektir. Samimi tevbe umut kapısını açık tutar."
        },
        {
          "field": "title",
          "value": "Zikrin Etkisi"
        },
        {
          "field": "summary",
          "value": "Zikir, kalbi gafletten uyandırır ve kişiyi Allah'ı hatırlama halinde tutar. Az ama devamlı zikir çoğu zaman dağınık ve düzensiz tekrardan daha bereketlidir."
        },
        {
          "field": "title",
          "value": "Duanın Adabı"
        },
        {
          "field": "summary",
          "value": "Dua, kulun ihtiyacını ve acziyetini Rabbi önünde dile getirmesidir. İçtenlik, ısrar ve helal hassasiyeti duanın ruhunu güçlendirir."
        },
        {
          "field": "title",
          "value": "Sabır"
        },
        {
          "field": "summary",
          "value": "Sabır, pasifçe beklemek değil; doğru olanı koruyarak zorluk içinde sebat etmektir. Mümin için sabır, dağılmadan ayakta kalma ahlakıdır."
        },
        {
          "field": "title",
          "value": "Şükür"
        },
        {
          "field": "summary",
          "value": "Şükür, nimeti sadece sözle anmak değil; o nimeti Allah'ın rızasına uygun kullanmaktır. Şükür kalbi yumuşatır ve nimet farkındalığını artırır."
        },
        {
          "field": "title",
          "value": "Gıybetten Sakınmak"
        },
        {
          "field": "summary",
          "value": "Gıybet, bir kişinin hoşlanmayacağı yönünü arkasından dile getirmektir. Dilin korunması, kalbin korunmasının da önemli bir parçasıdır."
        },
        {
          "field": "title",
          "value": "Kul Hakkı"
        },
        {
          "field": "summary",
          "value": "Kul hakkı sadece maddi zarar değildir; kırıcı söz, haksız itham ve güveni zedelemek de bu kapsama girebilir. Mümin, helalleşmeyi ve adaleti önemser."
        }
      ]
    },
    "ZikrimDuaVeTesbihat/Data/quran_dataset.json": {
      "count": 6236,
      "items_sample": [
        {
          "field": "turkish",
          "value": "Rahman (ve) rahim (olan) Allah'ın adıyla."
        },
        {
          "field": "turkish",
          "value": "Hamd (övme ve övülme), alemlerin Rabbi Allah'a mahsustur."
        },
        {
          "field": "turkish",
          "value": "O, rahmandır ve rahimdir."
        },
        {
          "field": "turkish",
          "value": "Ceza gününün malikidir."
        },
        {
          "field": "turkish",
          "value": "(Rabbimiz!) Ancak sana kulluk ederiz ve yalnız senden medet umarız."
        },
        {
          "field": "turkish",
          "value": "Bize doğru yolu göster."
        },
        {
          "field": "turkish",
          "value": "Kendilerine lütuf ve ikramda bulunduğun kimselerin yolunu; gazaba uğramışların ve sapmışların yolunu değil!"
        },
        {
          "field": "turkish",
          "value": "Elif. Lam. Mim."
        },
        {
          "field": "turkish",
          "value": "O kitap (Kur'an); onda asla şüphe yoktur. O, müttakiler (sakınanlar ve arınmak isteyenler) için bir yol göstericidir."
        },
        {
          "field": "turkish",
          "value": "Onlar gayba inanırlar, namaz kılarlar, kendilerine verdiğimiz mallardan Allah yolunda harcarlar."
        },
        {
          "field": "turkish",
          "value": "Yine onlar, sana indirilene ve senden önce indirilene iman ederler; ahiret gününe de kesinkes inanırlar."
        },
        {
          "field": "turkish",
          "value": "İşte onlar, Rablerinden gelen bir hidayet üzeredirler ve kurtuluşa erenler de ancak onlardır."
        },
        {
          "field": "turkish",
          "value": "Gerçek şu ki, kafir olanları (azap ile) korkutsan da korkutmasan da onlar için birdir; iman etmezler."
        },
        {
          "field": "turkish",
          "value": "Allah onların kalplerini ve kulaklarını mühürlemiştir. Onların gözlerine de bir çeşit perde gerilmiştir ve onlar için (dünya ve ahirette) büyük bir azap vardır."
        },
        {
          "field": "turkish",
          "value": "İnsanlardan bazıları da vardır ki, inanmadıkları halde \"Allah'a ve ahiret gününe inandık\" derler."
        },
        {
          "field": "turkish",
          "value": "Onlar (kendi akıllarınca) güya Allah'ı ve müminleri aldatırlar. Halbuki onlar ancak kendilerini aldatırlar ve bunun farkında değillerdir."
        },
        {
          "field": "turkish",
          "value": "Onların kalblerinde bir hastalık vardır. Allah da onların hastalığını çoğaltmıştır. Söylemekte oldukları yalanlar sebebiyle de onlar için elim bir azap vardır."
        },
        {
          "field": "turkish",
          "value": "Onlara: Yeryüzünde fesat çıkarmayın, denildiği zaman, \"Biz ancak ıslah edicileriz\" derler."
        },
        {
          "field": "turkish",
          "value": "Şunu bilin ki, onlar bozguncuların ta kendileridir, lakin anlamazlar."
        },
        {
          "field": "turkish",
          "value": "Onlara: İnsanların iman ettiği gibi siz de iman edin, denildiği vakit \"Biz hiç, sefihlerin (akılsız ve ahmak kişilerin) iman ettikleri gibi iman eder miyiz!\" derler. Biliniz ki, sefihler ancak kendileridir, fakat bunu bilmezler (veya bilmezlikten gelirler)."
        }
      ]
    }
  }
